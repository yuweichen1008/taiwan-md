type MindMapNode = {
  id: string;
  label: string;
  group: string;
  size: number;
  color: string;
  url?: string;
};

// Build hero mindmap data
const mindmapNodes: MindMapNode[] = [
  {
    id: 'taiwan',
    label: t('resources.mindmap.root.label'),
    group: 'center',
    size: 26,
    color: '#065f46',
  },
];

const mindmapEdges: { source: string; target: string }[] = [];

// Add category nodes and edges (only hero data)
heroData.categories.forEach((category) => {
  mindmapNodes.push({
    id: category.id,
    label: category.label,
    group: category.id,
    size: 16,
    color: category.color,
  });
  mindmapEdges.push({ source: 'taiwan', target: category.id });

  // Add site nodes
  category.sites.forEach((site, index) => {
    const nodeId = `${category.id}_${index}`;
    mindmapNodes.push({
      id: nodeId,
      label: site.name,
      group: category.id,
      size: 8,
      color: category.color,
      url: site.url,
    });
    mindmapEdges.push({ source: category.id, target: nodeId });
  });
});

const mindmapData = JSON.stringify({
  nodes: mindmapNodes,
  edges: mindmapEdges,
});
