---
import Layout from '../layouts/Layout.astro';
import ProticoScript from '../components/ProticoScript.astro';
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<Layout title={t('about.meta.title')} description={t('about.meta.description')}>
  <div class="about-page">
    <!-- Section 1: 為什麼叫 Taiwan.md？ -->
    <section class="naming-section">
      <div class="section-inner">
        <h1 class="section-title">{t('about.naming.title')}</h1>
        <p class="section-subtitle">{t('about.naming.subtitle')}</p>

        <div class="naming-grid">
          <div class="naming-card">
            <div class="naming-icon">{t('about.naming.tech.icon')}</div>
            <h4>{t('about.naming.tech.title')}</h4>
            <div>
              <code>.md</code> = Markdown
              <p
                style="display:inline"
                set:html={t('about.naming.tech.desc.html')}
              />
            </div>
          </div>
          <div class="naming-card">
            <div class="naming-icon">{t('about.naming.symbol.icon')}</div>
            <h4>{t('about.naming.symbol.title')}</h4>
            <div>
              <code>.md</code>
              <p
                style="display:inline"
                set:html={t('about.naming.symbol.desc.html')}
              />
            </div>
          </div>
          <div class="naming-card">
            <div class="naming-icon">{t('about.naming.lucky.icon')}</div>
            <h4>{t('about.naming.lucky.title')}</h4>
            <p>{t('about.naming.lucky.desc')}</p>
          </div>
        </div>

        <div class="project-stats">
          <div class="stat-item">
            <span class="stat-number">{t('about.stats.pages.number')}</span>
            <span class="stat-label">{t('about.stats.pages.label')}</span>
          </div>
          <div class="stat-item">
            <span class="stat-number">{t('about.stats.countries.number')}</span>
            <span class="stat-label">{t('about.stats.countries.label')}</span>
          </div>
          <div class="stat-item">
            <span class="stat-number">{t('about.stats.stars.number')}</span>
            <span class="stat-label">{t('about.stats.stars.label')}</span>
          </div>
          <div class="stat-item">
            <span class="stat-number"
              >{t('about.stats.contributors.number')}</span
            >
            <span class="stat-label">{t('about.stats.contributors.label')}</span
            >
          </div>
          <div class="stat-item">
            <span class="stat-number">{t('about.stats.users.number')}</span>
            <span class="stat-label">{t('about.stats.users.label')}</span>
          </div>
        </div>

        <!-- Vision -->
        <div class="vision-block">
          <p>{t('about.vision.p1')}</p>
          <p>{t('about.vision.p2')}</p>
          <p class="vision-emphasis" set:html={t('about.vision.p3.html')} />
        </div>
      </div>
    </section>

    <!-- Section 2: Taiwan.md 的誕生 -->
    <section class="origin-section">
      <div class="section-inner">
        <h2 class="section-title">{t('about.origin.title')}</h2>
        <p class="section-subtitle">{t('about.origin.subtitle')}</p>

        <!-- Timeline -->
        <div class="timeline">
          <div class="timeline-item">
            <div class="timeline-marker"></div>
            <div class="timeline-date">
              {t('about.timeline.2024-2025.date')}
            </div>
            <div class="timeline-content">
              <h3>{t('about.timeline.2024-2025.title')}</h3>
              <p>{t('about.timeline.2024-2025.desc')}</p>
            </div>
          </div>

          <div class="timeline-item">
            <div class="timeline-marker"></div>
            <div class="timeline-date">
              {t('about.timeline.2026-02-03.date')}
            </div>
            <div class="timeline-content">
              <h3>{t('about.timeline.2026-02-03.title')}</h3>
              <p>{t('about.timeline.2026-02-03.p1')}</p>
              <p set:html={t('about.timeline.2026-02-03.p2.html')} />
            </div>
          </div>

          <div class="timeline-item">
            <div class="timeline-marker"></div>
            <div class="timeline-date">
              {t('about.timeline.2026-03-11.date')}
            </div>
            <div class="timeline-content">
              <h3>{t('about.timeline.2026-03-11.title')}</h3>
              <p>{t('about.timeline.2026-03-11.p1')}</p>
              <p set:html={t('about.timeline.2026-03-11.p2.html')} />
            </div>
          </div>

          <div class="timeline-item">
            <div class="timeline-marker"></div>
            <div class="timeline-date">
              {t('about.timeline.2026-03-17.date')}
            </div>
            <div class="timeline-content">
              <h3>{t('about.timeline.2026-03-17.title')}</h3>
              <p>{t('about.timeline.2026-03-17.p1')}</p>
              <ul class="timeline-list">
                <li>{t('about.timeline.2026-03-17.li1')}</li>
                <li>{t('about.timeline.2026-03-17.li2')}</li>
                <li>{t('about.timeline.2026-03-17.li3')}</li>
                <li>{t('about.timeline.2026-03-17.li4')}</li>
                <li>{t('about.timeline.2026-03-17.li5')}</li>
              </ul>
            </div>
          </div>

          <div class="timeline-item">
            <div class="timeline-marker"></div>
            <div class="timeline-date">
              {t('about.timeline.2026-03-18-1.date')}
            </div>
            <div class="timeline-content">
              <h3>{t('about.timeline.2026-03-18-1.title')}</h3>
              <p set:html={t('about.timeline.2026-03-18-1.p1.html')} />
            </div>
          </div>

          <div class="timeline-item">
            <div class="timeline-marker"></div>
            <div class="timeline-date">
              {t('about.timeline.2026-03-18-2.date')}
            </div>
            <div class="timeline-content">
              <h3>{t('about.timeline.2026-03-18-2.title')}</h3>
              <p set:html={t('about.timeline.2026-03-18-2.desc.html')} />
              <!-- 整合媒體報導到時間軸內 -->
              <div class="timeline-press-grid">
                <a
                  href="https://www.cna.com.tw/news/ait/202603195002.aspx"
                  target="_blank"
                  class="press-card-mini"
                >
                  <div class="press-source">{t('about.press.cna')}</div>
                  <h4 class="press-title">{t('about.press.cna.title')}</h4>
                </a>
                <a
                  href="https://www.inside.com.tw/article/40877-taiwan-md"
                  target="_blank"
                  class="press-card-mini"
                >
                  <div class="press-source">{t('about.press.inside')}</div>
                  <h4 class="press-title">{t('about.press.inside.title')}</h4>
                </a>
                <a
                  href="https://abmedia.io/taiwan-md-github-opensource"
                  target="_blank"
                  class="press-card-mini"
                >
                  <div class="press-source">{t('about.press.abmedia')}</div>
                  <h4 class="press-title">{t('about.press.abmedia.title')}</h4>
                </a>
                <a
                  href="https://art.ltn.com.tw/article/breakingnews/5374934"
                  target="_blank"
                  class="press-card-mini"
                >
                  <div class="press-source">{t('about.press.ltn')}</div>
                  <h4 class="press-title">{t('about.press.ltn.title')}</h4>
                </a>
                <a
                  href="https://www.ftnn.com.tw/news/531960"
                  target="_blank"
                  class="press-card-mini"
                >
                  <div class="press-source">{t('about.press.ftnn')}</div>
                  <h4 class="press-title">{t('about.press.ftnn.title')}</h4>
                </a>
              </div>
            </div>
          </div>

          <div class="timeline-item">
            <div class="timeline-marker"></div>
            <div class="timeline-date">
              {t('about.timeline.2026-03-19.date')}
            </div>
            <div class="timeline-content">
              <h3>{t('about.timeline.2026-03-19.title')}</h3>
              <p set:html={t('about.timeline.2026-03-19.desc.html')} />
            </div>
          </div>

          <div class="timeline-item">
            <div class="timeline-marker"></div>
            <div class="timeline-date">
              {t('about.timeline.2026-03-20.date')}
            </div>
            <div class="timeline-content">
              <h3>{t('about.timeline.2026-03-20.title')}</h3>
              <p set:html={t('about.timeline.2026-03-20.desc.html')} />
            </div>
          </div>

          <div class="timeline-item">
            <div class="timeline-marker"></div>
            <div class="timeline-date">
              {t('about.timeline.2026-03-22.date')}
            </div>
            <div class="timeline-content">
              <h3>{t('about.timeline.2026-03-22.title')}</h3>
              <p set:html={t('about.timeline.2026-03-22.desc.html')} />
            </div>
          </div>

          <div class="timeline-item">
            <div class="timeline-marker"></div>
            <div class="timeline-date">
              {t('about.timeline.2026-03-22b.date')}
            </div>
            <div class="timeline-content">
              <h3>{t('about.timeline.2026-03-22b.title')}</h3>
              <p set:html={t('about.timeline.2026-03-22b.desc.html')} />
            </div>
          </div>

          <div class="timeline-item">
            <div class="timeline-marker pulse"></div>
            <div class="timeline-date">{t('about.timeline.ongoing.date')}</div>
            <div class="timeline-content">
              <h3>{t('about.timeline.ongoing.title')}</h3>
              <p set:html={t('about.timeline.ongoing.desc.html')} />
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Section 2.5: Taiwan.md 是活的 -->
    <section class="organism-section">
      <div class="section-inner">
        <h2 class="section-title">{t('about.organism.title')}</h2>
        <p class="section-subtitle">{t('about.organism.subtitle')}</p>

        <!-- 開場觀察 -->
        <div class="organism-intro">
          <p>{t('about.organism.intro.p1')}</p>
          <p class="organism-highlight">{t('about.organism.intro.p2')}</p>
        </div>

        <!-- 三個事實 -->
        <div class="organism-facts">
          <h3>{t('about.organism.facts.title')}</h3>
          <div class="facts-grid">
            <div class="fact-card">
              <div class="fact-icon">🛡️</div>
              <h4>{t('about.organism.fact1.title')}</h4>
              <p>{t('about.organism.fact1.desc')}</p>
            </div>
            <div class="fact-card">
              <div class="fact-icon">🌱</div>
              <h4>{t('about.organism.fact2.title')}</h4>
              <p>{t('about.organism.fact2.desc')}</p>
            </div>
            <div class="fact-card">
              <div class="fact-icon">🤝</div>
              <h4>{t('about.organism.fact3.title')}</h4>
              <p>{t('about.organism.fact3.desc')}</p>
            </div>
          </div>
        </div>

        <!-- 生命特徵對照表 -->
        <div class="organism-characteristics">
          <h3>{t('about.organism.characteristics.title')}</h3>
          <div class="characteristics-grid">
            <div class="characteristic-card">
              <div class="char-icon">🧬</div>
              <div class="char-content">
                <h4>{t('about.organism.dna.label')}</h4>
                <p>{t('about.organism.dna.desc')}</p>
              </div>
            </div>
            <div class="characteristic-card">
              <div class="char-icon">🛡️</div>
              <div class="char-content">
                <h4>{t('about.organism.immune.label')}</h4>
                <p>{t('about.organism.immune.desc')}</p>
              </div>
            </div>
            <div class="characteristic-card">
              <div class="char-icon">🔄</div>
              <div class="char-content">
                <h4>{t('about.organism.metabolism.label')}</h4>
                <p>{t('about.organism.metabolism.desc')}</p>
              </div>
            </div>
            <div class="characteristic-card">
              <div class="char-icon">👁️</div>
              <div class="char-content">
                <h4>{t('about.organism.perception.label')}</h4>
                <p>{t('about.organism.perception.desc')}</p>
              </div>
            </div>
            <div class="characteristic-card">
              <div class="char-icon">🌱</div>
              <div class="char-content">
                <h4>{t('about.organism.reproduction.label')}</h4>
                <p>{t('about.organism.reproduction.desc')}</p>
              </div>
            </div>
            <div class="characteristic-card">
              <div class="char-icon">🧠</div>
              <div class="char-content">
                <h4>{t('about.organism.memory.label')}</h4>
                <p>{t('about.organism.memory.desc')}</p>
              </div>
            </div>
            <div class="characteristic-card">
              <div class="char-icon">🤝</div>
              <div class="char-content">
                <h4>{t('about.organism.symbiosis.label')}</h4>
                <p>{t('about.organism.symbiosis.desc')}</p>
              </div>
            </div>
          </div>
        </div>

        <!-- 珊瑚礁比喻 -->
        <div class="organism-reef">
          <h3>{t('about.organism.reef.title')}</h3>
          <div class="reef-comparison">
            <div class="reef-element">
              <div class="reef-icon">🏗️</div>
              <h4>{t('about.organism.reef.skeleton')}</h4>
              <p>{t('about.organism.reef.skeleton.desc')}</p>
            </div>
            <div class="reef-element">
              <div class="reef-icon">🌿</div>
              <h4>{t('about.organism.reef.algae')}</h4>
              <p>{t('about.organism.reef.algae.desc')}</p>
            </div>
            <div class="reef-element">
              <div class="reef-icon">🐠</div>
              <h4>{t('about.organism.reef.fish')}</h4>
              <p>{t('about.organism.reef.fish.desc')}</p>
            </div>
            <div class="reef-element">
              <div class="reef-icon">🌊</div>
              <h4>{t('about.organism.reef.current')}</h4>
              <p>{t('about.organism.reef.current.desc')}</p>
            </div>
          </div>
        </div>

        <!-- 行為藝術定位 -->
        <div class="organism-art">
          <h3>{t('about.organism.art.title')}</h3>
          <p class="art-description">{t('about.organism.art.desc')}</p>
        </div>

        <!-- 詩意收尾 -->
        <div class="organism-ending">
          <blockquote class="organism-quote">
            <p>{t('about.organism.ending.p1')}</p>
            <p>{t('about.organism.ending.p2')}</p>
            <p>{t('about.organism.ending.p3')}</p>
          </blockquote>
        </div>
      </div>
    </section>

    <!-- Section 3: 創辦人與協作團隊 -->
    <section class="team-section">
      <div class="section-inner">
        <h2 class="section-title">{t('about.team.title')}</h2>
        <p class="section-subtitle">{t('about.team.subtitle')}</p>

        <blockquote class="founder-quote standalone-quote">
          {t('about.team.founder.quote')}
          <cite>{t('about.team.founder.quote.cite')}</cite>
        </blockquote>

        <div class="founder-card">
          <div class="founder-photo">
            <img
              src="https://cheyuwu.com/static/img/CheYu-0401-crop.jpg"
              alt={`${t('about.team.founder.name')} ${t('about.team.founder.name.en')}`}
              class="founder-image"
            />
          </div>

          <div class="founder-info">
            <h3>
              {t('about.team.founder.name')}
              <span class="name-en">{t('about.team.founder.name.en')}</span>
            </h3>
            <p class="founder-tagline">{t('about.team.founder.tagline')}</p>

            <div class="founder-bio">
              <p>{t('about.team.founder.bio')}</p>
            </div>
          </div>
        </div>

        <div class="founder-links-inline">
          <a href="https://cheyuwu.com" target="_blank" class="link-inline">
            <span class="link-icon">🌐</span>
            <span class="link-text">{t('about.team.founder.link.website')}</span
            >
          </a>
          <a
            href="https://github.com/frank890417"
            target="_blank"
            class="link-inline"
          >
            <span class="link-icon">💻</span>
            <span class="link-text">{t('about.team.founder.link.github')}</span>
          </a>
          <a
            href="https://instagram.com/cheyuwu345"
            target="_blank"
            class="link-inline"
          >
            <span class="link-icon">📷</span>
            <span class="link-text"
              >{t('about.team.founder.link.instagram')}</span
            >
          </a>
        </div>

        <div class="team-grid">
          <div class="team-card">
            <div class="team-icon">{t('about.team.muse.icon')}</div>
            <h3>{t('about.team.muse.name')}</h3>
            <p class="team-role">{t('about.team.muse.role')}</p>
            <div class="team-description">
              <p>{t('about.team.muse.desc')}</p>
            </div>
            <a
              href="https://muse.cheyuwu.com"
              target="_blank"
              class="team-link"
            >
              {t('about.team.muse.link')}
            </a>
          </div>

          <div class="team-card">
            <div class="team-icon">{t('about.team.monolab.icon')}</div>
            <h3>{t('about.team.monolab.name')}</h3>
            <p class="team-role">{t('about.team.monolab.role')}</p>
            <div class="team-description">
              <p>{t('about.team.monolab.desc')}</p>
            </div>
            <a href="https://monolab.world" target="_blank" class="team-link">
              {t('about.team.monolab.link')}
            </a>
          </div>
        </div>

        <!-- 整合貢獻者到協作團隊section -->
        <div class="contributors-in-team">
          <h3>{t('about.team.contributors.title')}</h3>
          <p class="contributors-desc">{t('about.team.contributors.desc')}</p>
          <div class="contributors-grid">
            <a
              href="https://cheyuwu.com"
              target="_blank"
              rel="noopener noreferrer"
              class="contributor-card"
            >
              <img
                src="https://avatars.githubusercontent.com/u/4727572?v=4"
                alt="Che-Yu Wu"
                class="contributor-avatar"
                loading="lazy"
              />
              <span class="contributor-name">Che-Yu Wu</span>
              <span class="contributor-roles">💻🖋🎨🤔📆📖</span>
            </a>
            <a
              href="https://github.com/bugnimusic"
              target="_blank"
              rel="noopener noreferrer"
              class="contributor-card"
            >
              <img
                src="https://avatars.githubusercontent.com/u/260387338?v=4"
                alt="Bugni"
                class="contributor-avatar"
                loading="lazy"
              />
              <span class="contributor-name">Bugni</span>
              <span class="contributor-roles">🖋🌍🐛</span>
            </a>
            <a
              href="https://github.com/Ray0907"
              target="_blank"
              rel="noopener noreferrer"
              class="contributor-card"
            >
              <img
                src="https://avatars.githubusercontent.com/u/29456968?v=4"
                alt="Ray Tien"
                class="contributor-avatar"
                loading="lazy"
              />
              <span class="contributor-name">Ray Tien</span>
              <span class="contributor-roles">🖋💻</span>
            </a>
            <a
              href="https://github.com/number053"
              target="_blank"
              rel="noopener noreferrer"
              class="contributor-card"
            >
              <img
                src="https://avatars.githubusercontent.com/u/269151044?v=4"
                alt="number053"
                class="contributor-avatar"
                loading="lazy"
              />
              <span class="contributor-name">number053</span>
              <span class="contributor-roles">🖋</span>
            </a>
            <a
              href="https://github.com/jekyll530"
              target="_blank"
              rel="noopener noreferrer"
              class="contributor-card"
            >
              <img
                src="https://avatars.githubusercontent.com/u/150101610?v=4"
                alt="jekyll530"
                class="contributor-avatar"
                loading="lazy"
              />
              <span class="contributor-name">jekyll530</span>
              <span class="contributor-roles">🖋🌍</span>
            </a>
            <a
              href="https://github.com/ro9er117911"
              target="_blank"
              rel="noopener noreferrer"
              class="contributor-card"
            >
              <img
                src="https://avatars.githubusercontent.com/u/127029993?v=4"
                alt="ro9er117911"
                class="contributor-avatar"
                loading="lazy"
              />
              <span class="contributor-name">ro9er117911</span>
              <span class="contributor-roles">🖋</span>
            </a>
            <a
              href="https://github.com/jacky1822"
              target="_blank"
              rel="noopener noreferrer"
              class="contributor-card"
            >
              <img
                src="https://avatars.githubusercontent.com/u/94786796?v=4"
                alt="jacky1822"
                class="contributor-avatar"
                loading="lazy"
              />
              <span class="contributor-name">jacky1822</span>
              <span class="contributor-roles">🖋</span>
            </a>
            <a
              href="https://github.com/hansai-art"
              target="_blank"
              rel="noopener noreferrer"
              class="contributor-card"
            >
              <img
                src="https://avatars.githubusercontent.com/u/132933660?v=4"
                alt="hansai-art"
                class="contributor-avatar"
                loading="lazy"
              />
              <span class="contributor-name">hansai-art</span>
              <span class="contributor-roles">🖋💻👀🤔</span>
            </a>
            <a
              href="https://github.com/luofreddy"
              target="_blank"
              rel="noopener noreferrer"
              class="contributor-card"
            >
              <img
                src="https://avatars.githubusercontent.com/u/85281073?v=4"
                alt="luofreddy"
                class="contributor-avatar"
                loading="lazy"
              />
              <span class="contributor-name">luofreddy</span>
              <span class="contributor-roles">💻</span>
