    border-radius: 16px;
    border: 1px solid #e5e7eb;
  }

  .contact-cta p {
    color: #4b5563;
    font-size: 1.05rem;
    margin-bottom: 1.5rem;
  }

  .cta-buttons {
    display: flex;
    gap: 1rem;
