            submitText: t('contribute.form.submit'),
            anonymousText:
              lang === 'en' ? 'Anonymous Contributor' : '匿名貢獻者',
          }}
        >
          document
            .getElementById('contribute-form')
            .addEventListener('submit', async function (e) {
              e.preventDefault();
              const btn = document.getElementById('submit-btn');
              btn.disabled = true;
              btn.textContent = submittingText;

              const data = {
                timestamp: new Date().toISOString(),
                content: document.getElementById('content').value,
                category: document.getElementById('category').value,
                sourceType: document.getElementById('source-type').value,
                sourceRef: document.getElementById('source-ref').value,
                name: document.getElementById('name').value || anonymousText,
                email: document.getElementById('email').value,
              };

              try {
                const SCRIPT_URL =
                  'https://script.google.com/macros/s/AKfycbzuS3eCR6-cga-OCN34YY34vi0KnkYXYOQLs0VgsMd7WoMAn-gX9OH70Yd_UyF23_5vUA/exec';
                await fetch(SCRIPT_URL, {
                  method: 'POST',
                  mode: 'no-cors',
                  headers: { 'Content-Type': 'application/json' },
                  body: JSON.stringify(data),
                });
                document.getElementById('contribute-form').style.display =
                  'none';
                document.getElementById('success-msg').style.display = 'block';
              } catch (err) {
                alert(errorMsg);
                btn.disabled = false;
                btn.textContent = submitText;
              }
            });
