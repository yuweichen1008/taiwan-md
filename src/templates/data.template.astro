    </section>

    <!-- Open Data & Digital Democracy -->
    <section class="opendata-section">
      <div class="section-divider">
        <div class="divider-line"></div>
      </div>

      <div class="story-intro">
        <h2 class="section-title">{t('data.openData.title')}</h2>
        <div class="story-text">
          <p>{t('data.openData.story.p1')}</p>
          <p>{t('data.openData.story.p2')}</p>
          <p>{t('data.openData.story.p3')}</p>
        </div>
      </div>

      <!-- Data Categories -->
      <div class="data-categories">
        {
          dataCategories.map((cat) => (
            <div class="data-category-card">
              <div class="category-header">
                <span class="category-icon">{cat.icon}</span>
                <div>
                  <h3 class="category-title">{cat.title}</h3>
                  <p class="category-desc">{cat.description}</p>
                </div>
              </div>
              <ul class="item-list">
                {cat.items.map((item) => (
                  <li class="item">
                    <a
                      href={item.url}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="item-link"
                    >
                      {item.name}
                    </a>
                    <span class="item-desc">— {item.desc}</span>
                  </li>
                ))}
              </ul>
            </div>
          ))
        }
      </div>
    </section>



    <!-- Footer -->
    <footer class="data-footer">
      <div class="section-divider">
        <div class="divider-line"></div>
      </div>

      <h3 class="footer-title">{t('data.footer.heading')}</h3>
      <div class="footer-links">
        <a href="/economy" class="footer-link">
          <span class="footer-icon">📈</span>
          <div class="footer-text">
            <span class="footer-name">{t('data.footer.link1.name')}</span>
            <span class="footer-desc">
              {t('data.footer.link1.description')}
            </span>
          </div>
