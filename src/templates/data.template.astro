                {t('data.svg.button.copy')}
              </button>
            </div>
          </div>
        </div>

        <div class="svg-card">
          <div class="svg-preview">
            <img
              src="/assets/svg/taiwan-political-division.svg"
              alt="Taiwan Political Division"
            />
          </div>
          <div class="svg-info">
            <h3>{t('data.svg.card4.title')}</h3>
            <p class="svg-desc">{t('data.svg.card4.description')}</p>
            <p class="svg-meta">Wikimedia Commons · CC</p>
            <div class="svg-actions">
              <a
                href="/assets/svg/taiwan-political-division.svg"
                download
                class="btn btn-primary"
              >
                {t('data.svg.button.download')}
              </a>
              <button
                class="btn btn-outline"
                onclick="copySVG('taiwan-political-division.svg', this)"
