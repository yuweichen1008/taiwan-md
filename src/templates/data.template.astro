      margin-bottom: 1rem;
      text-align: center;
    }

    .story-text {
      background: rgba(255, 255, 255, 0.03);
      border: 1px solid rgba(255, 255, 255, 0.08);
      border-radius: 16px;
      padding: 2rem;
    }

    .story-text p {
      color: #cbd5e1;
      line-height: 1.8;
      margin-bottom: 1rem;
      font-size: 1rem;
    }

    .story-text p:first-child {
      font-size: 1.1rem;
      color: #93c5fd;
      font-weight: 600;
    }

    .story-text p:last-child {
      margin-bottom: 0;
    }

    /* Enterprise Section */
    .companies-section {
      padding: 2rem 0 4rem;
