          </div>
        </div>
      </div>

      <!-- Usage Example -->
      <div class="usage-example">
        <h3>{t('data.svg.usage.heading')}</h3>
        <div class="code-block">
          <pre><code>&lt;!-- 直接嵌入 / Embed directly --&gt;
&lt;img src="https://taiwan.md/assets/svg/taiwan-icon-wiki.svg" alt="Taiwan" width="200"&gt;

&lt;!-- 作為 CSS 背景 / As CSS background --&gt;
background-image: url('https://taiwan.md/assets/svg/taiwan-icon-wiki.svg');

&lt;!-- 在 Markdown 中引用 / In Markdown --&gt;
![Taiwan](https://taiwan.md/assets/svg/taiwan-icon-wiki.svg)</code></pre>
        </div>
        <p class="license-note">
          {t('data.svg.usage.licenseNote')}
        </p>
