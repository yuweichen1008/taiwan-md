---
import {
  useTranslations,
  getLangFromUrl,
  useTranslatedPath,
} from '../i18n/utils';
import { getLangSwitchPath } from '../utils/getLangSwitchPath';

const currentPath = Astro.url.pathname;

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);

const { zhLink, enLink } = await getLangSwitchPath(currentPath);

const navConfig = [
  { path: '/#categories', label: t('nav.explore') },
  { path: '/graph', label: t('nav.graph') },
  { path: '/about', label: t('nav.about') },
  { path: '/contribute', label: t('nav.contribute') },
  { path: '/data', label: t('nav.data') },
  { path: '/resources', label: t('nav.resources') },
].map((item) => {
  const fullPath = translatePath(item.path);
  const pathWithoutHash = fullPath.replace(/#.*$/, '');
  const active =
    pathWithoutHash !== fullPath
      ? false
      : currentPath.startsWith(pathWithoutHash);
  return { ...item, fullPath, active };
});

const categoryList = [
  {
    path: translatePath('/history'),
    label: t('categoryConfig.history'),
    emoji: '📜',
  },
  {
    path: translatePath('/geography'),
    label: t('categoryConfig.geography'),
    emoji: '🗺️',
  },
  {
    path: translatePath('/culture'),
    label: t('categoryConfig.culture'),
    emoji: '🎭',
  },
  {
    path: translatePath('/food'),
    label: t('categoryConfig.food'),
    emoji: '🍜',
  },
  {
    path: translatePath('/art'),
    label: t('categoryConfig.art'),
    emoji: '🎨',
  },
  {
    path: translatePath('/music'),
    label: t('categoryConfig.music'),
    emoji: '🎵',
  },
  {
    path: translatePath('/technology'),
    label: t('categoryConfig.technology'),
    emoji: '💻',
  },
  {
    path: translatePath('/nature'),
    label: t('categoryConfig.nature'),
    emoji: '🌿',
  },
  {
    path: translatePath('/people'),
    label: t('categoryConfig.people'),
    emoji: '👥',
  },
  {
    path: translatePath('/society'),
    label: t('categoryConfig.society'),
    emoji: '🏛️',
  },
  {
    path: translatePath('/economy'),
    label: t('categoryConfig.economy'),
    emoji: '📊',
  },
  {
    path: translatePath('/lifestyle'),
    label: t('categoryConfig.lifestyle'),
    emoji: '🏠',
  },
];
---

<header role="banner">
  <div class="header-inner">
    <a href={translatePath('/')} class="logo" aria-label={t('nav.aria-home')}>
      <img
        src="/favicon.png"
        alt={t('nav.aria-img-label')}
        class="logo-icon"
        width="24"
        height="24"
      />
      <span class="logo-text">Taiwan<span class="logo-dot">.md</span></span>
    </a>
    <button
      class="menu-toggle"
      aria-label={t('nav.aria-toggle-menu')}
      onclick="document.querySelector('.nav-mobile').classList.toggle('open')"
      >☰</button
    >
    <nav class="nav-desktop" aria-label={t('nav.aria-main-navigation')}>
      {
        navConfig.map((item) => {
          if (item.path === '/#categories') {
            return (
              <div class="nav-dropdown">
                <a
                  href={item.fullPath}
                  class:list={['nav-link', { active: item.active }]}
                >
                  {item.label} <span class="dropdown-arrow">▾</span>
                </a>
                <div class="dropdown-menu">
                  {categoryList.map((category) => (
                    <a href={category.path} class="dropdown-item">
                      {category.emoji} {category.label}
                    </a>
                  ))}
                </div>
              </div>
            );
          }
          return (
            <a
              href={item.fullPath}
              class:list={['nav-link', { active: item.active }]}
            >
              {item.label}
            </a>
          );
        })
      }
      <a
        href="https://github.com/frank890417/taiwan-md"
        target="_blank"
        class="nav-link gh"
      >
        <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor"
          ><path
            d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"
          ></path></svg
        >
        GitHub
      </a>
    </nav>
    <nav class="nav-mobile" aria-label={t('nav.aria-mobile-navigation')}>
      {
        navConfig.map((item) => {
          if (item.path === '/assets') {
            return null;
          }
          return (
            <a
              href={item.fullPath}
              class:list={['nav-link', { active: item.active }]}
              onclick="document.querySelector('.nav-mobile').classList.remove('open')"
            >
              {item.label}
            </a>
          );
        })
      }
      <a
        href="https://github.com/frank890417/taiwan-md"
        target="_blank"
        class="nav-link">GitHub</a
      >
      <div class="mobile-lang-toggle">
        <span class="mobile-lang-label"
          >{`🌐 ${t('nav.language-switch')}:`}</span
        >
        <div class="mobile-lang-buttons">
          <a
            href={zhLink}
            class:list={[
              'mobile-lang-btn',
              { active: !currentPath.startsWith('/en') },
            ]}
            onclick="document.querySelector('.nav-mobile').classList.remove('open')"
            >中文</a
          >
          <a
            href={enLink}
            class:list={[
              'mobile-lang-btn',
              { active: currentPath.startsWith('/en') },
            ]}
            onclick="document.querySelector('.nav-mobile').classList.remove('open')"
            >English</a
          >
        </div>
      </div>
    </nav>
    <button
      class="search-toggle"
      aria-label={t('nav.aria-search')}
      onclick="document.getElementById('search-modal').classList.add('open');setTimeout(()=>document.getElementById('search-input').focus(),100)"
    >
      <svg
        width="16"
        height="16"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        ><circle cx="11" cy="11" r="8"></circle><line
          x1="21"
          y1="21"
          x2="16.65"
          y2="16.65"></line></svg
      >
    </button>
    <div
      class="lang-toggle"
      role="group"
      aria-label={t('nav.aria-language-selection')}
    >
      <a
        href={zhLink}
        class:list={['lang-btn', { active: !currentPath.startsWith('/en') }]}
        aria-label={t('nav.aria-switch-to-zh-tw')}>中文</a
      >
      <a
        href={enLink}
        class:list={['lang-btn', { active: currentPath.startsWith('/en') }]}
        aria-label={t('nav.aria-switch-to-en')}>EN</a
      >
    </div>
  </div>
</header>
<!-- Search Modal -->
<div id="search-modal" class="search-modal">
  <div
    class="search-backdrop"
    onclick="document.getElementById('search-modal').classList.remove('open')"
  >
  </div>
  <div class="search-panel">
    <div class="search-header">
      <svg
        width="18"
        height="18"
        viewBox="0 0 24 24"
        fill="none"
        stroke="#94a3b8"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        ><circle cx="11" cy="11" r="8"></circle><line
          x1="21"
          y1="21"
          x2="16.65"
          y2="16.65"></line></svg
      >
      <input
        id="search-input"
        type="text"
        placeholder={`${t('nav.search-modal.input-placeholder')}...`}
        autocomplete="off"
      />
      <kbd
        class="search-kbd"
        onclick="document.getElementById('search-modal').classList.remove('open')"
        >ESC</kbd
      >
    </div>
    <div id="search-results" class="search-results">
      <div class="search-hint">
        {t('nav.search-modal.type-to-search')}
      </div>
    </div>
  </div>
</div>
<style>
  /* Header */
  header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgba(255, 255, 255, 0.92);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(0, 0, 0, 0.06);
  }
  .header-inner {
    max-width: var(--container-wide);
    margin: 0 auto;
    padding: 0.7rem var(--space-page-x);
    display: flex;
    align-items: center;
    gap: 1.25rem;
  }
  .logo {
    text-decoration: none;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 1.25rem;
    font-weight: 700;
    color: #1a1a2e;
  }
  .logo-icon {
    width: 1.4rem;
    height: 1.4rem;
    vertical-align: middle;
  }
  .logo-dot {
    color: #3b82f6;
  }
  nav {
    display: flex;
    gap: 0.35rem;
    margin-left: auto;
  }
  /* Dropdown */
  .nav-dropdown {
    position: relative;
  }
  .dropdown-arrow {
    font-size: 0.65em;
    opacity: 0.5;
    margin-left: 2px;
  }
  .dropdown-menu {
    display: none;
    position: absolute;
    top: 100%;
    left: 50%;
    transform: translateX(-50%);
    background: rgba(255, 255, 255, 0.98);
    backdrop-filter: blur(12px);
    border: 1px solid rgba(167, 196, 160, 0.4);
    border-radius: 12px;
    padding: 0.5rem 0;
    min-width: 160px;
    box-shadow: 0 12px 32px rgba(15, 23, 42, 0.12);
    z-index: 1000;
  }
  .nav-dropdown:hover .dropdown-menu {
    display: block;
  }
  .dropdown-item {
    display: block;
    padding: 0.45rem 1.1rem;
    color: #2d5016;
    text-decoration: none;
    font-size: 0.85rem;
    font-weight: 500;
    white-space: nowrap;
    transition: background 0.15s ease;
  }
  .dropdown-item:hover {
    background: rgba(74, 124, 89, 0.08);
  }

  .nav-link {
    text-decoration: none;
    color: #475569;
    font-size: 0.9rem;
    font-weight: 500;
    transition: all 0.2s ease;
    display: flex;
    align-items: center;
    gap: 0.35rem;
    position: relative;
    padding: 0.55rem 0.65rem;
    white-space: nowrap;
    border-radius: 999px;
  }
  .nav-link:hover {
    color: #1a1a2e;
    text-decoration: none;
    background: rgba(148, 163, 184, 0.12);
  }
  .nav-link:hover::after {
    display: none;
  }
  .nav-link.active {
    color: #1a1a2e;
    font-weight: 600;
    background: rgba(59, 130, 246, 0.1);
  }
  .nav-link.active::after {
    content: '';
    position: absolute;
    bottom: 7px;
    left: 0.8rem;
    right: 0.8rem;
    height: 2px;
    background: #3b82f6;
  }
  .nav-link.gh svg {
    opacity: 0.7;
  }
  /* Search toggle button */
  .search-toggle {
    display: flex;
    align-items: center;
    justify-content: center;
    background: none;
    border: 1px solid rgba(0, 0, 0, 0.08);
    border-radius: 6px;
    padding: 0.4rem;
    cursor: pointer;
    color: #64748b;
    transition: all 0.2s;
  }
  .search-toggle:hover {
    color: #1a1a2e;
    border-color: rgba(0, 0, 0, 0.15);
    background: rgba(0, 0, 0, 0.03);
  }

  /* Search modal */
  .search-modal {
    display: none;
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 100;
    align-items: flex-start;
    justify-content: center;
    padding-top: 12vh;
  }
  .search-modal.open {
    display: flex;
  }
  .search-backdrop {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(0, 0, 0, 0.4);
    backdrop-filter: blur(4px);
  }
  .search-panel {
    position: relative;
    width: 90%;
    max-width: 560px;
    background: white;
    border-radius: 12px;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.2);
    overflow: hidden;
  }
  .search-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.9rem 1rem;
    border-bottom: 1px solid #e2e8f0;
  }
  .search-header input {
    flex: 1;
    border: none;
    outline: none;
    font-size: 1rem;
    color: #1a1a2e;
    background: transparent;
  }
  .search-header input::placeholder {
    color: #94a3b8;
  }
  .search-kbd {
    font-size: 0.7rem;
    padding: 0.2rem 0.5rem;
    background: #f1f5f9;
    border: 1px solid #e2e8f0;
    border-radius: 4px;
    color: #64748b;
    font-family: inherit;
    cursor: pointer;
  }
  .search-results {
    max-height: 400px;
    overflow-y: auto;
    padding: 0.5rem;
  }
  .search-hint {
    padding: 2rem 1rem;
    text-align: center;
    color: #94a3b8;
    font-size: 0.9rem;
  }
  .search-item {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    padding: 0.7rem 0.75rem;
    border-radius: 8px;
    text-decoration: none;
    color: inherit;
    transition: background 0.15s;
    border-bottom: none;
  }
  .search-item:hover {
    background: #f1f5f9;
  }
  .search-item-lang {
    flex-shrink: 0;
    font-size: 0.7rem;
    font-weight: 600;
    padding: 0.15rem 0.4rem;
    border-radius: 4px;
    background: #e2e8f0;
    color: #64748b;
    margin-top: 0.15rem;
  }
  .search-item-text {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    min-width: 0;
  }
  .search-item-title {
    font-size: 0.95rem;
    font-weight: 600;
    color: #1a1a2e;
  }
  .search-item-desc {
    font-size: 0.8rem;
    color: #64748b;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .lang-toggle {
    display: flex;
    gap: 2px;
    background: rgba(241, 245, 249, 0.95);
    border: var(--border-soft);
    border-radius: 10px;
    padding: 3px;
    flex-shrink: 0;
    box-shadow: 0 6px 18px rgba(15, 23, 42, 0.05);
  }
  .lang-btn {
    padding: 0.4rem 0.8rem;
    text-decoration: none;
    color: #475569;
    font-size: 0.85rem;
    font-weight: 600;
    border-radius: 6px;
    transition: all 0.2s;
    min-width: 40px;
    text-align: center;
  }
  .lang-btn:hover {
    background: rgba(59, 130, 246, 0.1);
    color: #3b82f6;
  }
  .lang-btn.active {
    background: #3b82f6;
    color: white;
    box-shadow: 0 2px 4px rgba(59, 130, 246, 0.25);
  }

  .menu-toggle {
    display: none;
    background: none;
    border: none;
    font-size: 1.4rem;
    cursor: pointer;
    color: #334155;
    padding: 0.25rem;
  }
  .nav-mobile {
    display: none;
  }

  @media (max-width: 768px) {
    .header-inner {
      padding: 0.7rem 1rem;
      gap: 0.75rem;
    }
    .logo {
      font-size: 1.05rem;
    }
    .nav-desktop {
      display: none;
    }
    .menu-toggle {
      display: block;
      order: 4;
      margin-left: 0.15rem;
      width: 2.5rem;
      height: 2.5rem;
      border-radius: 999px;
      background: #f8fafc;
      border: 1px solid #e2e8f0;
    }
    .search-toggle {
      order: 2;
    }
    .lang-toggle {
      order: 3;
      margin-left: auto;
    }
    .search-panel {
      max-width: 100%;
      width: 95%;
    }
    .search-modal {
      padding-top: 8vh;
    }
    .nav-mobile {
      display: none;
      position: absolute;
      top: 100%;
      left: 0.75rem;
      right: 0.75rem;
      margin-top: 0.35rem;
      background: rgba(255, 255, 255, 0.99);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      flex-direction: column;
      padding: 0.8rem 1rem 1rem;
      gap: 0;
      border: 1px solid rgba(0, 0, 0, 0.08);
      border-radius: 18px;
      box-shadow: 0 18px 42px rgba(15, 23, 42, 0.14);
    }
    .nav-mobile.open {
      display: flex;
    }
    .nav-mobile .nav-link {
      padding: 0.85rem 0.2rem;
      font-size: 0.95rem;
      border-bottom: 1px solid #f1f5f9;
      position: relative;
      border-radius: 0;
      background: transparent;
    }
    .nav-mobile .nav-link:hover::after {
      display: none; /* 移動端不顯示底線效果 */
    }
    .nav-mobile .nav-link.active {
      color: #1a1a2e;
      font-weight: 600;
      background: rgba(59, 130, 246, 0.05);
      margin: 0 -1rem;
      padding-left: 1rem;
      padding-right: 1rem;
      border-radius: 8px;
    }
    .mobile-lang-toggle {
      padding: 1rem 0 0.5rem;
      border-top: 1px solid #e2e8f0;
    }
    .mobile-lang-label {
      font-size: 0.85rem;
      color: #64748b;
      font-weight: 500;
      display: block;
      margin-bottom: 0.75rem;
    }
    .mobile-lang-buttons {
      display: flex;
      gap: 0.5rem;
    }
    .mobile-lang-btn {
      flex: 1;
      padding: 0.6rem;
      text-align: center;
      text-decoration: none;
      color: #475569;
      background: #f8fafc;
      border: 1px solid #e2e8f0;
      border-radius: 6px;
      font-size: 0.9rem;
      font-weight: 600;
      transition: all 0.2s;
    }
    .mobile-lang-btn.active {
      background: #3b82f6;
      color: white;
      border-color: #3b82f6;
    }
    .mobile-lang-btn:not(.active):hover {
      background: #e2e8f0;
    }
  }
</style>
