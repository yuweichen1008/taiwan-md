---
import SEO from '../components/SEO.astro';
import { readdir, readFile } from 'fs/promises';
import { resolve, join, basename } from 'path';
import matter from 'gray-matter';

interface Props {
  title: string;
  description?: string;
  lang?: 'zh-TW' | 'en';
  image?: string;
  type?: 'website' | 'article';
  datePublished?: string;
  dateModified?: string;
  content?: string;
  tags?: string[];
  category?: string;
}

const { lang = 'zh-TW' } = Astro.props;
const {
  title,
  description = lang === 'en' ? 'Open-source knowledge base about Taiwan' : '讓全世界完整認識台灣',
  image,
  type,
  datePublished,
  dateModified,
  content,
  tags,
  category,
} = Astro.props;

// Build search index at build time
const categoryMapping: Record<string, string> = {
  history: 'History',
  geography: 'Geography',
  culture: 'Culture',
  food: 'Food',
  art: 'Art',
  music: 'Music',
  technology: 'Technology',
  nature: 'Nature',
  people: 'People',
  society: 'Society',
  economy: 'Economy',
  lifestyle: 'Lifestyle',
};

const searchIndex: Array<{
  t: string;
  d: string;
  u: string;
  tags: string[];
  lang: string;
}> = [];

for (const [slug, folder] of Object.entries(categoryMapping)) {
  // Chinese articles
  try {
    const zhPath = resolve(process.cwd(), 'knowledge', folder);
    const files = await readdir(zhPath);
    for (const file of files.filter(
      (f) => f.endsWith('.md') && !f.startsWith('_'),
    )) {
      const { data } = matter(await readFile(join(zhPath, file), 'utf-8'));
      const name = basename(file, '.md');
      searchIndex.push({
        t: data.title || name,
        d: data.description || '',
        u: `/${slug}/${name}`,
        tags: data.tags || [],
        lang: 'zh-TW',
      });
    }
  } catch {}
  // English articles
  try {
    const enPath = resolve(process.cwd(), 'knowledge', 'en', folder);
    const files = await readdir(enPath);
    for (const file of files.filter(
      (f) => f.endsWith('.md') && !f.startsWith('_'),
    )) {
      const { data } = matter(await readFile(join(enPath, file), 'utf-8'));
      const name = basename(file, '.md');
      searchIndex.push({
        t: data.title || name,
        d: data.description || '',
        u: `/en/${slug}/${name}`,
        tags: data.tags || [],
        lang: 'en',
      });
    }
  } catch {}
}
const currentPath = Astro.url.pathname;
const isEn = lang === 'en';
const categorySlug = category?.toLowerCase() || '';
const jfClass = categorySlug ? `jf-${categorySlug}` : '';

const i18n = {
  nav: {
    explore: isEn ? 'Explore' : '探索',
    graph: isEn ? 'Graph' : '🕸️ 圖譜',
    map: isEn ? 'Map' : '地圖',
    about: isEn ? 'About' : '關於',
    contribute: isEn ? 'Contribute' : '貢獻',
    resources: isEn ? 'Resources' : '資源',
    data: isEn ? 'Data' : '數據',
    assets: isEn ? 'SVG Assets' : 'SVG 素材',
    projects: isEn ? 'Projects' : '專案',
  },
  footer: {
    explore: isEn ? 'Explore' : '探索',
    history: isEn ? 'History' : '歷史',
    culture: isEn ? 'Culture' : '文化',
    food: isEn ? 'Food' : '美食',
    technology: isEn ? 'Technology' : '科技',
    nature: isEn ? 'Nature' : '自然',
    society: isEn ? 'Society' : '社會',
    project: isEn ? 'Project' : '專案',
    about: isEn ? 'About' : '關於',
    graph: isEn ? 'Knowledge Graph' : '知識圖譜',
    contribute: isEn ? 'Contribute Guide' : '貢獻指南',
    changelog: isEn ? 'Update History' : '更新紀錄',
    contact: isEn ? 'Connect' : '聯繫',
    report: isEn ? 'Report Issue' : '回報問題',
    discuss: isEn ? 'Discussions' : '討論區',
    desc: isEn
      ? 'Open-source, AI-friendly knowledge base about Taiwan'
      : '開源、AI-friendly 的台灣知識庫',
  },
};

// Language switch logic
let zhLink = '/';
let enLink = '/en';

if (currentPath.startsWith('/en')) {
  // Current is EN, switch to ZH: remove /en prefix
  zhLink = currentPath.replace(/^\/en/, '') || '/';
  enLink = currentPath;
} else {
  // Current is ZH, switch to EN: add /en prefix
  zhLink = currentPath;
  enLink = '/en' + (currentPath === '/' ? '' : currentPath);
}

const navConfig = [
  { path: '/#categories', label: i18n.nav.explore },
  { path: '/graph', label: i18n.nav.graph },
  { path: '/about', label: i18n.nav.about },
  { path: '/contribute', label: i18n.nav.contribute },
  { path: '/resources', label: i18n.nav.resources },
  { path: '/data', label: i18n.nav.data },
  { path: '/assets', label: i18n.nav.assets },
  { path: '/projects', label: i18n.nav.projects },
].map((item) => {
  const fullPath = isEn ? `/en${item.path}` : item.path;
  const pathWithoutHash = fullPath.replace(/#.*$/, '');
  const active =
    pathWithoutHash !== fullPath
      ? false
      : currentPath.startsWith(pathWithoutHash);
  return { ...item, fullPath, active };
});
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Noto+Serif+TC:wght@400;600;700;900&display=swap"
      rel="stylesheet"
