---
import SEO from '../components/SEO.astro';

interface Props {
  title: string;
  description?: string;
  lang?: 'zh-TW' | 'en';
  image?: string;
  type?: 'website' | 'article';
  datePublished?: string;
  dateModified?: string;
  content?: string;
}

const { title, description = '讓全世界完整認識台灣', lang = 'zh-TW', image, type, datePublished, dateModified, content } = Astro.props;
const currentPath = Astro.url.pathname;
const isEn = lang === 'en';

const i18n = {
  nav: {
    explore: isEn ? 'Explore' : '探索',
    graph: isEn ? 'Graph' : '🕸️ 圖譜',
    map: isEn ? 'Map' : '地圖',
    about: isEn ? 'About' : '關於',
    contribute: isEn ? 'Contribute' : '貢獻',
    resources: isEn ? 'Resources' : '資源',
    assets: isEn ? 'SVG Assets' : 'SVG 素材',
    projects: isEn ? 'Projects' : '專案',
  },
  footer: {
    explore: isEn ? 'Explore' : '探索',
    history: isEn ? 'History' : '歷史',
    culture: isEn ? 'Culture' : '文化',
    food: isEn ? 'Food' : '美食',
    technology: isEn ? 'Technology' : '科技',
    nature: isEn ? 'Nature' : '自然',
    society: isEn ? 'Society' : '社會',
    project: isEn ? 'Project' : '專案',
    about: isEn ? 'About' : '關於',
    graph: isEn ? 'Knowledge Graph' : '知識圖譜',
    contribute: isEn ? 'Contribute Guide' : '貢獻指南',
    changelog: isEn ? 'Update History' : '更新紀錄',
    contact: isEn ? 'Connect' : '聯繫',
    report: isEn ? 'Report Issue' : '回報問題',
    discuss: isEn ? 'Discussions' : '討論區',
    desc: isEn ? 'Open-source, AI-friendly knowledge base about Taiwan' : '開源、AI-friendly 的台灣知識庫',
  }
};

// Language switch logic
let zhLink = '/';
let enLink = '/en';

if (currentPath.startsWith('/en')) {
  // Current is EN, switch to ZH: remove /en prefix
  zhLink = currentPath.replace(/^\/en/, '') || '/';
  enLink = currentPath;
} else {
  // Current is ZH, switch to EN: add /en prefix
  zhLink = currentPath;
  enLink = '/en' + (currentPath === '/' ? '' : currentPath);
}
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Noto+Serif+TC:wght@400;600;700;900&display=swap" rel="stylesheet" />
    <title>{title} | Taiwan.md</title>
    <SEO title={title} description={description} lang={lang} image={image} type={type} datePublished={datePublished} dateModified={dateModified} content={content} />
    <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-JGC5W00N7T"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-JGC5W00N7T');
    </script>
  </head>
  <body>
    <div id="lang-banner" class="lang-banner" style="display:none;">
      <span>🌐 English version available → <a href={enLink}>Switch to English</a></span>
      <button class="lang-banner-close" onclick="document.getElementById('lang-banner').style.display='none';localStorage.setItem('lang-banner-dismissed','1');" aria-label="Close">✕</button>
    </div>
    <script is:inline>
      (function() {
        if (localStorage.getItem('lang-banner-dismissed')) return;
        var lang = navigator.language || navigator.userLanguage || '';
        if (lang.startsWith('zh')) return;
        if (window.location.pathname.startsWith('/en')) return;
        var b = document.getElementById('lang-banner');
        if (b) b.style.display = 'flex';
      })();
    </script>
    <header>
      <div class="header-inner">
        <a href={isEn ? "/en" : "/"} class="logo">
          <img src="/favicon.png" alt="🇹🇼" class="logo-icon" width="24" height="24" />
          <span class="logo-text">Taiwan<span class="logo-dot">.md</span></span>
        </a>
        <button class="menu-toggle" aria-label="選單" onclick="document.querySelector('.nav-mobile').classList.toggle('open')">☰</button>
        <nav class="nav-desktop">
          <a href={isEn ? "/en#categories" : "/#categories"} class="nav-link">{i18n.nav.explore}</a>
          <a href={isEn ? "/en/graph" : "/graph"} class="nav-link">{i18n.nav.graph}</a>
          <!-- Map hidden temporarily -->
          <a href={isEn ? "/en/about" : "/about"} class="nav-link">{i18n.nav.about}</a>
          <a href={isEn ? "/en/contribute" : "/contribute"} class="nav-link">{i18n.nav.contribute}</a>
          <a href={isEn ? "/en/resources" : "/resources"} class="nav-link">{i18n.nav.resources}</a>
          <!-- SVG Assets hidden temporarily -->
          <a href={isEn ? "/en/projects" : "/projects"} class="nav-link">{i18n.nav.projects}</a>
          <a href="https://github.com/frank890417/taiwan-md" target="_blank" class="nav-link gh">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/></svg>
            GitHub
          </a>
        </nav>
        <nav class="nav-mobile">
          <a href={isEn ? "/en#categories" : "/#categories"} class="nav-link" onclick="document.querySelector('.nav-mobile').classList.remove('open')">{i18n.nav.explore}</a>
          <a href={isEn ? "/en/graph" : "/graph"} class="nav-link" onclick="document.querySelector('.nav-mobile').classList.remove('open')">{i18n.nav.graph}</a>
          <!-- Map hidden temporarily -->
          <a href={isEn ? "/en/about" : "/about"} class="nav-link" onclick="document.querySelector('.nav-mobile').classList.remove('open')">{i18n.nav.about}</a>
          <a href={isEn ? "/en/contribute" : "/contribute"} class="nav-link" onclick="document.querySelector('.nav-mobile').classList.remove('open')">{i18n.nav.contribute}</a>
          <a href={isEn ? "/en/resources" : "/resources"} class="nav-link" onclick="document.querySelector('.nav-mobile').classList.remove('open')">{i18n.nav.resources}</a>
          <!-- SVG Assets hidden temporarily -->
          <a href={isEn ? "/en/projects" : "/projects"} class="nav-link" onclick="document.querySelector('.nav-mobile').classList.remove('open')">{i18n.nav.projects}</a>
          <a href="https://github.com/frank890417/taiwan-md" target="_blank" class="nav-link">GitHub</a>
          <div class="mobile-lang-toggle">
            <span class="mobile-lang-label">🌐 語言 / Language:</span>
            <div class="mobile-lang-buttons">
              <a href={zhLink} class:list={["mobile-lang-btn", { active: !currentPath.startsWith('/en') }]} onclick="document.querySelector('.nav-mobile').classList.remove('open')">中文</a>
              <a href={enLink} class:list={["mobile-lang-btn", { active: currentPath.startsWith('/en') }]} onclick="document.querySelector('.nav-mobile').classList.remove('open')">English</a>
            </div>
          </div>
        </nav>
        <div class="lang-toggle">
          <a href={zhLink} class:list={["lang-btn", { active: !currentPath.startsWith('/en') }]}>中文</a>
          <a href={enLink} class:list={["lang-btn", { active: currentPath.startsWith('/en') }]}>EN</a>
        </div>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer>
      <div class="footer-inner">
        <div class="footer-grid">
          <div class="footer-brand">
            <span class="footer-logo">🇹🇼 Taiwan.md</span>
            <p>{i18n.footer.desc}</p>
            <p class="footer-heart">Built with ❤️ in Taiwan</p>
            <p class="footer-license">
              <a href="https://creativecommons.org/licenses/by-sa/4.0/deed.zh-tw" target="_blank" rel="noopener">
                <svg width="16" height="16" viewBox="0 0 496 512" fill="currentColor" style="margin-right: 6px;">
                  <path d="M245.83 214.87l-33.22 17.28c-9.43-19.58-25.24-19.93-27.46-19.93-22.13 0-33.22 14.61-33.22 43.84 0 23.57 9.21 43.84 33.22 43.84 14.47 0 24.65-7.09 30.57-21.26l30.55 15.5c-6.17 11.51-25.69 38.98-65.1 38.98-22.6 0-73.96-10.32-73.96-77.05 0-58.69 43-77.06 72.63-77.06 30.72-.01 52.7 11.95 65.99 35.86zm143.05 0l-32.78 17.28c-9.5-19.77-25.72-19.93-27.9-19.93-22.14 0-33.22 14.61-33.22 43.84 0 23.55 9.23 43.84 33.22 43.84 14.45 0 24.65-7.09 30.54-21.26l31.04 15.5c-6.17 11.51-25.69 38.98-65.09 38.98-22.69 0-73.96-9.87-73.96-77.05 0-58.67 42.97-77.06 72.6-77.06 30.71-.01 52.58 11.95 65.55 35.86zM247.56 8.05C104.74 8.05 0 123.11 0 256.05c0 138.49 113.6 248 247.56 248 129.93 0 248.44-100.87 248.44-248 0-137.87-106.62-248-248.44-248zm.87 450.81c-112.54 0-203.7-93.04-203.7-202.81 0-105.42 85.43-203.27 203.72-203.27 112.53 0 202.82 89.46 202.82 203.26-.01 121.69-99.68 202.82-202.84 202.82z"/>
                </svg>
                CC BY-SA 4.0
              </a>
            </p>
            <p class="footer-eth">
              <span class="footer-eth-label">{isEn ? 'Support us' : '支持我們'}:</span>
              <code class="footer-eth-address">taiwanmd.eth</code>
            </p>
          </div>
          <div class="footer-col">
            <h4>{i18n.footer.explore}</h4>
            <a href={isEn ? "/en/history" : "/history"}>{i18n.footer.history}</a>
            <a href={isEn ? "/en/culture" : "/culture"}>{i18n.footer.culture}</a>
            <a href={isEn ? "/en/food" : "/food"}>{i18n.footer.food}</a>
            <a href={isEn ? "/en/technology" : "/technology"}>{i18n.footer.technology}</a>
            <a href={isEn ? "/en/nature" : "/nature"}>{i18n.footer.nature}</a>
            <a href={isEn ? "/en/society" : "/society"}>{i18n.footer.society}</a>
          </div>
          <div class="footer-col">
            <h4>{i18n.footer.project}</h4>
            <a href="https://github.com/frank890417/taiwan-md" target="_blank">GitHub</a>
            <a href={isEn ? "/en/about" : "/about"}>{i18n.footer.about}</a>
            <a href={isEn ? "/en/graph" : "/graph"}>{i18n.footer.graph}</a>
            <a href="https://github.com/frank890417/taiwan-md/blob/main/CONTRIBUTING.md" target="_blank">{i18n.footer.contribute}</a>
            <a href={isEn ? "/en/changelog" : "/changelog"}>{i18n.footer.changelog}</a>
          </div>
          <div class="footer-col">
            <h4>{i18n.footer.contact}</h4>
            <a href="https://x.com/taiwandotmd" target="_blank">𝕏 @taiwandotmd</a>
            <a href="https://www.threads.com/@taiwandotmd" target="_blank">Threads @taiwandotmd</a>
            <a href="https://www.instagram.com/taiwandotmd" target="_blank">IG @taiwandotmd</a>
            <a href="mailto:cheyu.wu@monoame.com">cheyu.wu@monoame.com</a>
            <a href="https://github.com/frank890417/taiwan-md/issues" target="_blank">{i18n.footer.report}</a>
            <a href="https://github.com/frank890417/taiwan-md/discussions" target="_blank">{i18n.footer.discuss}</a>
          </div>
        </div>
        <div class="footer-bottom">
          &copy; 2026 Taiwan.md — {i18n.footer.desc}
        </div>
      </div>
    </footer>

    <!-- Floating .md button -->
    <a id="md-btn" class="floating-md" title="查看 Raw Markdown 版本" target="_blank">
      .md
    </a>

    <script is:inline>
      // Set .md button href based on current path
      const btn = document.getElementById('md-btn');
      const pathname = window.location.pathname;
      const ghBase = 'https://github.com/frank890417/taiwan-md/blob/main';
      
      let target = '/README.md'; // Default fallback

      // Handle special pages
      if (pathname === '/' || pathname === '/en' || pathname === '/en/' || pathname === '/index.html') {
        target = '/README.md';
      } else if (pathname.includes('/contribute')) {
        target = '/CONTRIBUTING.md';
      } else if (pathname.includes('/resources')) {
        target = '/knowledge/About/台灣官方網站資源.md';
      } else if (pathname.includes('/graph')) {
        target = '/src/pages/graph.astro';
      } else if (pathname.includes('/map')) {
        target = pathname.startsWith('/en') ? '/src/pages/en/map.astro' : '/src/pages/map.astro';
      } else if (pathname.includes('/about')) {
        target = '/src/pages/about.astro';
      } else {
        // Content pages (Categories or Articles)
        const isEn = pathname.startsWith('/en/');
        // Remove /en/ prefix and leading/trailing slashes
        const cleanPath = pathname.replace(/^\/en/, '').replace(/^\//, '').replace(/\/$/, '').replace('index.html', '');
        const parts = cleanPath.split('/');
        
        if (parts.length > 0 && parts[0]) {
          const cat = parts[0];
          // Capitalize first letter of category (history -> History)
          const catFolder = cat.charAt(0).toUpperCase() + cat.slice(1);
          
          // ZH source is in knowledge/Category, EN source is in knowledge/en/Category
          const prefix = isEn ? '/knowledge/en' : '/knowledge';
          
          if (parts.length === 1) {
            // Category Hub: knowledge/History/_History Hub.md
            target = `${prefix}/${catFolder}/_${catFolder} Hub.md`;
          } else {
            // Article: knowledge/History/article-name.md
            const slug = decodeURIComponent(parts.slice(1).join('/')); 
            target = `${prefix}/${catFolder}/${slug}.md`;
          }
        }
      }
      
      btn.href = ghBase + target;

      // Set active nav links
      document.addEventListener('DOMContentLoaded', function() {
        const currentPath = window.location.pathname;
        const navLinks = document.querySelectorAll('.nav-link[href]');
        
        navLinks.forEach(link => {
          const href = link.getAttribute('href');
          // Match exact path or check if current path starts with link href (for categories)
          if (href === currentPath || 
              (href !== '/' && currentPath.startsWith(href)) ||
              (href === '/#categories' && currentPath !== '/' && currentPath !== '/about' && currentPath !== '/contribute' && currentPath !== '/graph')) {
            link.classList.add('active');
          }
        });
      });
    </script>
  </body>
</html>

<style is:global>
  :root {
    --container-wide: 1380px;
    --container-page: 1180px;
    --container-reading: 800px;
    --space-page-x: clamp(1rem, 2vw, 2rem);
    --space-section-y: clamp(3.5rem, 7vw, 6rem);
    --space-1: 0.5rem;
    --space-2: 0.75rem;
    --space-3: 1rem;
    --space-4: 1.5rem;
    --space-5: 2rem;
    --space-6: 2.5rem;
    --space-7: 3rem;
    --space-8: 4rem;
    --space-9: 5rem;
    --radius-chip: 16px;
    --radius-card: 20px;
    --radius-pill: 999px;
    --shadow-soft: 0 8px 30px rgba(15, 23, 42, 0.06);
    --shadow-card: 0 16px 40px rgba(15, 23, 42, 0.08);
    --border-soft: 1px solid rgba(148, 163, 184, 0.2);
    --font-editorial: "Noto Serif TC", "Source Han Serif TC", "PMingLiU", serif;
    --title-display-size: clamp(2.25rem, 5vw, 3.2rem);
    --title-section-size: clamp(1.95rem, 4vw, 2.5rem);
    --title-subsection-size: clamp(1.3rem, 2.4vw, 1.7rem);
    --title-minor-size: 1.1rem;
    --title-line-height: 1.2;
    --title-letter-spacing: 0.03em;
    --copy-intro-size: clamp(1rem, 1.6vw, 1.08rem);
    --copy-intro-line: 1.75;
    --copy-intro-color: #64748b;
    --copy-intro-width: 42rem;
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  .lang-banner {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    padding: 0.6rem 1rem;
    background: linear-gradient(90deg, #1e3a5f, #2563eb);
    color: white;
    font-size: 0.85rem;
    text-align: center;
  }
  .lang-banner a { color: #fbbf24; font-weight: 600; text-decoration: underline; }
  .lang-banner a:hover { color: #fde68a; }
  .lang-banner-close {
    background: none; border: none; color: rgba(255,255,255,0.7);
    font-size: 1rem; cursor: pointer; padding: 0 0.3rem;
  }
  .lang-banner-close:hover { color: white; }
  
  body {
    font-family: "Noto Serif TC", "Source Han Serif TC", "PMingLiU", serif;
    font-weight: 600;
    line-height: 1.6;
    color: #1a1a2e;
    background:
      radial-gradient(circle at top, rgba(226, 232, 240, 0.35), transparent 30%),
      linear-gradient(180deg, #ffffff 0%, #f8fafc 100%);
    -webkit-font-smoothing: antialiased;
  }

  /* Header */
  header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgba(255, 255, 255, 0.92);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(0, 0, 0, 0.06);
  }
  .header-inner {
    max-width: var(--container-wide);
    margin: 0 auto;
    padding: 0.7rem var(--space-page-x);
    display: flex;
    align-items: center;
    gap: 1.25rem;
  }
  .logo {
    text-decoration: none;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 1.25rem;
    font-weight: 700;
    color: #1a1a2e;
  }
  .logo-icon { width: 1.4rem; height: 1.4rem; vertical-align: middle; }
  .logo-dot { color: #3b82f6; }
  nav {
    display: flex;
    gap: 0.35rem;
    margin-left: auto;
  }
  .nav-link {
    text-decoration: none;
    color: #475569;
    font-size: 0.9rem;
    font-weight: 500;
    transition: all 0.2s ease;
    display: flex;
    align-items: center;
    gap: 0.35rem;
    position: relative;
    padding: 0.55rem 0.8rem;
    white-space: nowrap;
    border-radius: 999px;
  }
  .nav-link:hover { 
    color: #1a1a2e; 
    text-decoration: none;
    background: rgba(148, 163, 184, 0.12);
  }
  .nav-link:hover::after {
    display: none;
  }
  .nav-link.active {
    color: #1a1a2e;
    font-weight: 600;
    background: rgba(59, 130, 246, 0.1);
  }
  .nav-link.active::after {
    content: '';
    position: absolute;
    bottom: 7px;
    left: 0.8rem;
    right: 0.8rem;
    height: 2px;
    background: #3b82f6;
  }
  .nav-link.gh svg { opacity: 0.7; }
  .lang-toggle {
    display: flex;
    gap: 2px;
    background: rgba(241, 245, 249, 0.95);
    border: var(--border-soft);
    border-radius: 10px;
    padding: 3px;
    flex-shrink: 0;
    box-shadow: 0 6px 18px rgba(15, 23, 42, 0.05);
  }
  .lang-btn {
    padding: 0.4rem 0.8rem;
    text-decoration: none;
    color: #475569;
    font-size: 0.85rem;
    font-weight: 600;
    border-radius: 6px;
    transition: all 0.2s;
    min-width: 40px;
    text-align: center;
  }
  .lang-btn:hover {
    background: rgba(59, 130, 246, 0.1);
    color: #3b82f6;
  }
  .lang-btn.active {
    background: #3b82f6;
    color: white;
    box-shadow: 0 2px 4px rgba(59, 130, 246, 0.25);
  }

  /* Main - full width */
  main {
    min-height: calc(100vh - 60px);
  }
  main img {
    max-width: 100%;
    max-height: 400px;
    object-fit: cover;
    border-radius: 12px;
  }

  /* Footer */
  footer {
    background: #1a2e1a;
    color: #94a3b8;
    padding: 3rem 0 1.5rem;
  }
  .footer-inner {
    max-width: var(--container-wide);
    margin: 0 auto;
    padding: 0 var(--space-page-x);
  }
  .footer-grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr;
    gap: 2rem;
    margin-bottom: 2rem;
  }
  .footer-logo {
    font-size: 1.2rem;
    font-weight: 700;
    color: white;
    display: block;
    margin-bottom: 0.5rem;
  }
  .footer-heart { color: #22c55e; margin-top: 0.5rem; }
  .footer-license {
    margin-top: 0.75rem;
  }
  .footer-license a {
    color: #a7c7a7;
    text-decoration: none;
    font-size: 0.8rem;
    display: inline-flex;
    align-items: center;
    transition: all 0.2s ease;
  }
  .footer-license a:hover {
    color: #c7d2c7;
  }
  .footer-eth {
    margin-top: 0.6rem;
    font-size: 0.8rem;
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }
  .footer-eth-label { color: #94a3b8; }
  .footer-eth-address {
    font-family: 'SF Mono', 'Fira Code', monospace;
    color: #a7c7a7;
    font-size: 0.8rem;
    background: rgba(255,255,255,0.06);
    padding: 0.15rem 0.5rem;
    border-radius: 4px;
    letter-spacing: 0.02em;
  }
  .footer-col {
    display: flex;
    flex-direction: column;
