        </a>
        <button
          class="menu-toggle"
          aria-label={isEn ? "Toggle navigation menu" : "開啟/關閉導航選單"}
          onclick="document.querySelector('.nav-mobile').classList.toggle('open')"
          >☰</button
        >
        <nav class="nav-desktop" aria-label={isEn ? "Main navigation" : "主要導航"}>
          {
            navConfig.map((item) => {
              if (item.path === '/#categories') {
                return (
                  <div class="nav-dropdown">
                    <a
                      href={item.fullPath}
                      class:list={['nav-link', { active: item.active }]}
                    >
                      {item.label} <span class="dropdown-arrow">▾</span>
                    </a>
                    <div class="dropdown-menu">
                      <a
                        href={isEn ? '/en/history' : '/history'}
                        class="dropdown-item"
                      >
                        📜 {isEn ? 'History' : '歷史'}
                      </a>
                      <a
                        href={isEn ? '/en/geography' : '/geography'}
                        class="dropdown-item"
                      >
                        🗺️ {isEn ? 'Geography' : '地理'}
                      </a>
                      <a
                        href={isEn ? '/en/culture' : '/culture'}
                        class="dropdown-item"
                      >
                        🎭 {isEn ? 'Culture' : '文化'}
                      </a>
                      <a
                        href={isEn ? '/en/food' : '/food'}
                        class="dropdown-item"
                      >
                        🍜 {isEn ? 'Food' : '美食'}
                      </a>
                      <a href={isEn ? '/en/art' : '/art'} class="dropdown-item">
                        🎨 {isEn ? 'Art' : '藝術'}
                      </a>
                      <a
                        href={isEn ? '/en/music' : '/music'}
                        class="dropdown-item"
                      >
                        🎵 {isEn ? 'Music' : '音樂'}
                      </a>
                      <a
                        href={isEn ? '/en/technology' : '/technology'}
                        class="dropdown-item"
                      >
                        💻 {isEn ? 'Technology' : '科技'}
                      </a>
                      <a
                        href={isEn ? '/en/nature' : '/nature'}
                        class="dropdown-item"
                      >
                        🌿 {isEn ? 'Nature' : '自然'}
                      </a>
                      <a
                        href={isEn ? '/en/people' : '/people'}
                        class="dropdown-item"
                      >
                        👥 {isEn ? 'People' : '人物'}
                      </a>
                      <a
                        href={isEn ? '/en/society' : '/society'}
                        class="dropdown-item"
                      >
                        🏛️ {isEn ? 'Society' : '社會'}
                      </a>
                      <a
                        href={isEn ? '/en/economy' : '/economy'}
                        class="dropdown-item"
                      >
                        📊 {isEn ? 'Economy' : '經濟'}
                      </a>
                      <a
                        href={isEn ? '/en/lifestyle' : '/lifestyle'}
                        class="dropdown-item"
                      >
                        🏠 {isEn ? 'Lifestyle' : '生活'}
                      </a>
                    </div>
                  </div>
                );
              }
              return (
                <a
                  href={item.fullPath}
                  class:list={['nav-link', { active: item.active }]}
                >
                  {item.label}
                </a>
              );
            })
          }
          <a
            href="https://github.com/frank890417/taiwan-md"
            target="_blank"
            class="nav-link gh"
          >
            <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor"
              ><path
                d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"
              ></path></svg
            >
            GitHub
          </a>
        </nav>
        <nav class="nav-mobile" aria-label={isEn ? "Mobile navigation" : "行動裝置導航"}>
          {
            navConfig.map((item) => {
              if (item.path === '/assets') {
                return null;
              }
              return (
                <a
                  href={item.fullPath}
                  class:list={['nav-link', { active: item.active }]}
                  onclick="document.querySelector('.nav-mobile').classList.remove('open')"
                >
                  {item.label}
                </a>
              );
            })
          }
          <a
            href="https://github.com/frank890417/taiwan-md"
            target="_blank"
            class="nav-link">GitHub</a
          >
          <div class="mobile-lang-toggle">
            <span class="mobile-lang-label">{isEn ? '🌐 Language:' : '🌐 語言 / Language:'}</span>
            <div class="mobile-lang-buttons">
              <a
                href={zhLink}
                class:list={[
                  'mobile-lang-btn',
                  { active: !currentPath.startsWith('/en') },
                ]}
                onclick="document.querySelector('.nav-mobile').classList.remove('open')"
                >中文</a
              >
              <a
                href={enLink}
                class:list={[
                  'mobile-lang-btn',
                  { active: currentPath.startsWith('/en') },
                ]}
                onclick="document.querySelector('.nav-mobile').classList.remove('open')"
                >English</a
              >
            </div>
          </div>
        </nav>
        <button
          class="search-toggle"
          aria-label={isEn ? 'Search' : '搜尋'}
          onclick="document.getElementById('search-modal').classList.add('open');setTimeout(()=>document.getElementById('search-input').focus(),100)"
        >
          <svg
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            ><circle cx="11" cy="11" r="8"></circle><line
              x1="21"
              y1="21"
              x2="16.65"
              y2="16.65"></line></svg
          >
        </button>
        <div class="lang-toggle" role="group" aria-label={isEn ? "Language selection" : "語言選擇"}>
          <a
            href={zhLink}
            class:list={[
              'lang-btn',
              { active: !currentPath.startsWith('/en') },
            ]}
            aria-label={isEn ? "Switch to Traditional Chinese" : "切換至繁體中文"}>中文</a
          >
          <a
            href={enLink}
            class:list={['lang-btn', { active: currentPath.startsWith('/en') }]}
            aria-label="Switch to English">EN</a
          >
        </div>
      </div>
    </header>

    <!-- Search Modal -->
    <div id="search-modal" class="search-modal">
      <div
        class="search-backdrop"
        onclick="document.getElementById('search-modal').classList.remove('open')"
      >
      </div>
      <div class="search-panel">
        <div class="search-header">
          <svg
            width="18"
            height="18"
            viewBox="0 0 24 24"
            fill="none"
            stroke="#94a3b8"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            ><circle cx="11" cy="11" r="8"></circle><line
              x1="21"
              y1="21"
              x2="16.65"
              y2="16.65"></line></svg
          >
          <input
            id="search-input"
            type="text"
            placeholder={isEn ? 'Search articles...' : '搜尋文章...'}
            autocomplete="off"
          />
          <kbd
            class="search-kbd"
            onclick="document.getElementById('search-modal').classList.remove('open')"
            >ESC</kbd
          >
        </div>
        <div id="search-results" class="search-results">
          <div class="search-hint">
            {
              isEn
                ? 'Type to search across all articles'
                : '輸入關鍵字搜尋所有文章'
            }
          </div>
        </div>
      </div>
    </div>
    <script is:inline define:vars={{ searchIndex, isEn }}>
      (function () {
        var idx = searchIndex;
        var lang = isEn ? 'en' : 'zh-TW';
        var input = document.getElementById('search-input');
        var results = document.getElementById('search-results');
        var modal = document.getElementById('search-modal');

        input.addEventListener('input', function () {
          var q = this.value.trim().toLowerCase();
          if (!q) {
            results.innerHTML =
              '<div class="search-hint">' +
              (isEn
                ? 'Type to search across all articles'
                : '輸入關鍵字搜尋所有文章') +
              '</div>';
            return;
          }
          var matches = idx.filter(function (item) {
            return (
              item.t.toLowerCase().indexOf(q) !== -1 ||
              item.d.toLowerCase().indexOf(q) !== -1 ||
              item.tags.some(function (tag) {
                return tag.toLowerCase().indexOf(q) !== -1;
              })
            );
          });
          // Prefer current language, then show others
          matches.sort(function (a, b) {
            var aLang = a.lang === lang ? 0 : 1;
            var bLang = b.lang === lang ? 0 : 1;
            return aLang - bLang;
          });
          if (matches.length === 0) {
            results.innerHTML =
              '<div class="search-hint">' +
              (isEn ? 'No results found' : '找不到相關文章') +
              '</div>';
            return;
          }
          var html = matches
            .slice(0, 12)
            .map(function (item) {
              var langBadge = item.lang === 'en' ? 'EN' : '中';
              return (
                '<a class="search-item" href="' +
                item.u +
                '">' +
                '<span class="search-item-lang">' +
                langBadge +
                '</span>' +
                '<div class="search-item-text">' +
                '<span class="search-item-title">' +
                item.t +
                '</span>' +
                (item.d
                  ? '<span class="search-item-desc">' + item.d + '</span>'
                  : '') +
                '</div>' +
                '</a>'
              );
            })
            .join('');
          if (matches.length > 12) {
            html +=
              '<div class="search-hint">' +
              (isEn
                ? '...and ' + (matches.length - 12) + ' more'
                : '...還有 ' + (matches.length - 12) + ' 篇') +
              '</div>';
          }
          results.innerHTML = html;
        });

        // ESC to close
        document.addEventListener('keydown', function (e) {
          if (e.key === 'Escape' && modal.classList.contains('open')) {
            modal.classList.remove('open');
          }
          // Cmd/Ctrl+K to open
          if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
            e.preventDefault();
            modal.classList.toggle('open');
