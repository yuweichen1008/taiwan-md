---
import Layout from '../layouts/Layout.astro';
---

<Layout title="台灣地圖 Map" description="以地圖視角探索 Taiwan.md 的內容脈絡">
  <div class="map-page">
    <section class="map-hero">
      <div class="hero-inner">
        <p class="hero-kicker">Map View</p>
        <h1>台灣地圖</h1>
        <p class="hero-subtitle">用地圖視角探索台灣的文化、美食、自然與歷史節點。</p>
      </div>
    </section>

    <section class="map-controls">
      <div class="controls-inner">
        <div class="filter-section">
          <h3>區域篩選</h3>
          <div class="filter-buttons" id="regionFilters">
            <button class="filter-btn active" data-filter="all">全部</button>
            <button class="filter-btn" data-filter="north">北部</button>
            <button class="filter-btn" data-filter="central">中部</button>
            <button class="filter-btn" data-filter="south">南部</button>
            <button class="filter-btn" data-filter="east">東部</button>
            <button class="filter-btn" data-filter="islands">離島</button>
          </div>
        </div>

        <div class="filter-section">
          <h3>分類篩選</h3>
          <div class="filter-buttons" id="categoryFilters">
            <button class="filter-btn active" data-filter="all">全部</button>
            <button class="filter-btn" data-filter="food">🍜 美食</button>
            <button class="filter-btn" data-filter="history">📜 歷史</button>
            <button class="filter-btn" data-filter="nature">🌿 自然</button>
            <button class="filter-btn" data-filter="culture">🎭 文化</button>
            <button class="filter-btn" data-filter="technology">💻 科技</button>
            <button class="filter-btn" data-filter="economy">📈 經濟</button>
            <button class="filter-btn" data-filter="lifestyle">🏮 生活</button>
            <button class="filter-btn" data-filter="art">🎨 藝術</button>
            <button class="filter-btn" data-filter="geography">🗺️ 地理</button>
          </div>
        </div>
      </div>
    </section>

    <section class="map-body">
      <div class="map-canvas">
        <svg id="taiwanMap" viewBox="0 0 800 1000" class="taiwan-svg">
          <!-- Taiwan main island -->
          <path 
            d="M400 100 
               C450 100, 480 130, 485 180
               C490 220, 485 260, 480 300
               C475 340, 470 380, 465 420
               C460 460, 455 500, 450 540
               C445 580, 440 620, 435 660
               C430 700, 425 740, 415 780
               C405 820, 390 850, 370 870
               C350 890, 320 895, 290 890
               C260 885, 230 875, 210 860
               C190 845, 175 825, 165 800
               C155 775, 150 745, 155 710
               C160 675, 170 640, 175 605
               C180 570, 175 535, 180 500
               C185 465, 195 430, 205 395
               C215 360, 225 325, 235 290
               C245 255, 255 220, 270 190
               C285 160, 310 135, 340 125
               C370 115, 390 105, 400 100 Z"
            fill="url(#taiwanGradient)"
            stroke="#2d5016"
            stroke-width="2"
            class="taiwan-mainland"
          />
          
          <!-- Penghu Islands -->
          <circle cx="150" cy="450" r="8" fill="#16a34a" class="island penghu" />
          
          <!-- Kinmen -->
          <circle cx="80" cy="400" r="6" fill="#16a34a" class="island kinmen" />
          
          <!-- Gradient definition -->
          <defs>
            <linearGradient id="taiwanGradient" x1="0%" y1="0%" x2="0%" y2="100%">
              <stop offset="0%" stop-color="#dcfce7" />
              <stop offset="50%" stop-color="#bbf7d0" />
              <stop offset="100%" stop-color="#86efac" />
            </linearGradient>
          </defs>

          <!-- Knowledge markers -->
          <g id="markers">
            <!-- North Region -->
            <circle cx="350" cy="200" r="8" fill="#f39c12" class="marker" data-region="north" data-category="food" data-title="士林夜市" data-link="/food/夜市文化" data-desc="台灣夜市文化的代表性據點"></circle>
            <circle cx="330" cy="180" r="8" fill="#27ae60" class="marker" data-region="north" data-category="nature" data-title="陽明山國家公園" data-link="/nature/國家公園" data-desc="台灣第一個國家公園"></circle>
            <circle cx="370" cy="220" r="8" fill="#ff5722" class="marker" data-region="north" data-category="economy" data-title="台北101" data-link="/economy/經濟奇蹟" data-desc="台灣經濟奇蹟的象徵"></circle>
            <circle cx="360" cy="210" r="8" fill="#e74c3c" class="marker" data-region="north" data-category="history" data-title="中正紀念堂" data-link="/history/戒嚴時期" data-desc="見證台灣戒嚴時期的歷史建築"></circle>
            <circle cx="365" cy="215" r="8" fill="#8bc34a" class="marker" data-region="north" data-category="lifestyle" data-title="西門町" data-link="/lifestyle/便利商店文化" data-desc="台灣便利商店文化發源地"></circle>
            <circle cx="380" cy="240" r="8" fill="#3498db" class="marker" data-region="north" data-category="technology" data-title="新竹科學園區" data-link="/technology/半導體產業" data-desc="台灣半導體產業重鎮"></circle>

            <!-- Central Region -->
            <circle cx="320" cy="420" r="8" fill="#27ae60" class="marker" data-region="central" data-category="nature" data-title="日月潭" data-link="/nature/國家公園" data-desc="台灣最美麗的高山湖泊"></circle>
            <circle cx="340" cy="380" r="8" fill="#9b59b6" class="marker" data-region="central" data-category="culture" data-title="鹿港" data-link="/culture/廟宇文化與民間信仰" data-desc="台灣廟宇文化的重要據點"></circle>
            <circle cx="360" cy="370" r="8" fill="#e91e63" class="marker" data-region="central" data-category="art" data-title="台中國家歌劇院" data-link="/art/當代藝術" data-desc="台灣當代藝術的重要場域"></circle>

            <!-- South Region -->
            <circle cx="320" cy="650" r="8" fill="#e74c3c" class="marker" data-region="south" data-category="history" data-title="台南府城" data-link="/history/荷西明鄭時期" data-desc="台灣歷史文化古都"></circle>
            <circle cx="340" cy="680" r="8" fill="#ff5722" class="marker" data-region="south" data-category="economy" data-title="高雄港" data-link="/economy/經濟奇蹟" data-desc="台灣重要的海港經濟據點"></circle>
            <circle cx="350" cy="800" r="8" fill="#27ae60" class="marker" data-region="south" data-category="nature" data-title="墾丁國家公園" data-link="/nature/國家公園" data-desc="台灣最南端的國家公園"></circle>
            <circle cx="300" cy="720" r="8" fill="#9b59b6" class="marker" data-region="south" data-category="culture" data-title="六堆客家文化" data-link="/culture/族群（閩南客家原住民外省新住民）" data-desc="南台灣客家文化保存區"></circle>

            <!-- East Region -->
            <circle cx="420" cy="350" r="8" fill="#27ae60" class="marker" data-region="east" data-category="nature" data-title="太魯閣國家公園" data-link="/nature/國家公園" data-desc="世界級的峽谷地景"></circle>
            <circle cx="430" cy="450" r="8" fill="#2ecc71" class="marker" data-region="east" data-category="geography" data-title="花東縱谷" data-link="/geography/台灣五大地形與地理結構" data-desc="台灣重要的地理景觀"></circle>
            <circle cx="480" cy="600" r="8" fill="#9b59b6" class="marker" data-region="east" data-category="culture" data-title="蘭嶼" data-link="/culture/原住民族文化" data-desc="原住民族文化保存地"></circle>
            <circle cx="425" cy="470" r="8" fill="#f39c12" class="marker" data-region="east" data-category="food" data-title="池上" data-link="/food/台灣茶文化" data-desc="台灣優質稻米產區"></circle>

            <!-- Islands -->
            <circle cx="150" cy="450" r="6" fill="#2ecc71" class="marker island-marker" data-region="islands" data-category="geography" data-title="澎湖" data-link="/geography/離島與海洋文化" data-desc="台灣海洋文化的代表"></circle>
            <circle cx="80" cy="400" r="6" fill="#e74c3c" class="marker island-marker" data-region="islands" data-category="history" data-title="金門" data-link="/history/戒嚴時期" data-desc="見證兩岸對峙的歷史"></circle>
          </g>
        </svg>

        <!-- Tooltip -->
        <div id="tooltip" class="tooltip">
          <div class="tooltip-title"></div>
          <div class="tooltip-category"></div>
          <div class="tooltip-desc"></div>
        </div>
      </div>

      <aside class="map-panel" id="infoPanel">
        <div class="panel-content" id="defaultContent">
          <h3>台灣知識地圖</h3>
          <div class="stats">
            <div class="stat-item">
              <span class="stat-number" id="totalMarkers">18</span>
              <span class="stat-label">個知識節點</span>
            </div>
            <div class="stat-item">
              <span class="stat-number">9</span>
              <span class="stat-label">個分類</span>
            </div>
          </div>
          
          <div class="category-distribution">
            <h4>分類分布</h4>
            <div class="category-list">
              <div class="category-item">
                <span class="category-color" style="background: #27ae60;"></span>
                <span>自然 (5)</span>
              </div>
              <div class="category-item">
                <span class="category-color" style="background: #e74c3c;"></span>
                <span>歷史 (3)</span>
              </div>
              <div class="category-item">
                <span class="category-color" style="background: #9b59b6;"></span>
                <span>文化 (3)</span>
              </div>
              <div class="category-item">
                <span class="category-color" style="background: #ff5722;"></span>
                <span>經濟 (2)</span>
              </div>
              <div class="category-item">
                <span class="category-color" style="background: #f39c12;"></span>
                <span>美食 (2)</span>
              </div>
            </div>
          </div>
          
          <div class="panel-links">
            <a class="panel-link" href="/graph">🕸️ 知識圖譜</a>
            <a class="panel-link" href="/">🏠 首頁分類</a>
          </div>
        </div>

        <div class="panel-content article-content" id="articleContent" style="display: none;">
          <button class="back-btn" id="backBtn">← 返回</button>
          <h3 id="articleTitle"></h3>
          <div class="article-meta">
            <span class="article-category" id="articleCategory"></span>
          </div>
          <p id="articleDesc"></p>
          <a id="articleLink" class="read-more-btn">閱讀全文 →</a>
        </div>
      </aside>
    </section>
  </div>
</Layout>

<style>
  .map-page {
    padding-bottom: 2rem;
  }

  .map-hero {
    background: linear-gradient(135deg, #f0fdf4, #dcfce7, #bbf7d0);
    padding: 3rem 1.5rem 2rem;
    border-bottom: 1px solid #d1fae5;
  }

  .hero-inner {
    max-width: 1200px;
    margin: 0 auto;
    text-align: center;
  }

  .hero-kicker {
    font-size: 0.9rem;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: #16a34a;
    margin-bottom: 0.5rem;
    font-weight: 600;
  }

  .map-hero h1 {
    font-size: 2.8rem;
    margin-bottom: 1rem;
    color: #2d5016;
    font-family: 'jf-lanyangming', 'Noto Serif TC', serif;
  }

  .hero-subtitle {
    font-size: 1.2rem;
    color: #15803d;
    max-width: 600px;
    margin: 0 auto;
  }

  .map-controls {
    background: #ffffff;
    border-bottom: 1px solid #e5e7eb;
    padding: 1.5rem 1rem;
  }

  .controls-inner {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: 2rem;
    align-items: start;
  }

  .filter-section h3 {
    font-size: 1rem;
    color: #374151;
    margin-bottom: 0.75rem;
    font-weight: 600;
  }

  .filter-buttons {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .filter-btn {
    padding: 0.5rem 1rem;
    border: 1px solid #d1d5db;
    background: #ffffff;
    border-radius: 20px;
    font-size: 0.85rem;
    cursor: pointer;
    transition: all 0.2s;
    color: #374151;
  }

  .filter-btn:hover {
    border-color: #16a34a;
    background: #f0fdf4;
  }

  .filter-btn.active {
    background: #16a34a;
    border-color: #16a34a;
    color: white;
  }

  .map-body {
    max-width: 1200px;
    margin: 0 auto;
    padding: 2rem 1rem;
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: 2rem;
    align-items: start;
  }

  .map-canvas {
    position: relative;
    background: #ffffff;
    border: 1px solid #e5e7eb;
    border-radius: 16px;
    padding: 1.5rem;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.05);
  }

  .taiwan-svg {
    width: 100%;
    height: auto;
    max-height: 700px;
    cursor: pointer;
  }

  .taiwan-mainland {
    transition: all 0.3s ease;
  }

  .taiwan-mainland:hover {
    filter: brightness(1.05);
  }

  .marker {
    cursor: pointer;
    transition: all 0.3s ease;
    filter: drop-shadow(0 2px 4px rgba(0,0,0,0.2));
  }

  .marker:hover {
    transform: scale(1.3);
    filter: drop-shadow(0 4px 8px rgba(0,0,0,0.3)) brightness(1.1);
  }

  .marker.hidden {
    opacity: 0;
    pointer-events: none;
  }

  .island {
    fill: #16a34a;
    stroke: #2d5016;
    stroke-width: 1;
  }

  .tooltip {
    position: absolute;
    background: rgba(0, 0, 0, 0.9);
    color: white;
    padding: 0.75rem;
    border-radius: 8px;
    font-size: 0.85rem;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.2s;
    z-index: 1000;
    max-width: 200px;
  }

  .tooltip-title {
    font-weight: 600;
    margin-bottom: 0.25rem;
  }

  .tooltip-category {
    font-size: 0.75rem;
    opacity: 0.8;
    margin-bottom: 0.25rem;
  }

  .tooltip-desc {
    font-size: 0.75rem;
    line-height: 1.3;
  }

  .map-panel {
    background: #ffffff;
    border: 1px solid #e5e7eb;
    border-radius: 16px;
    padding: 1.5rem;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.05);
    position: sticky;
    top: 2rem;
  }

  .panel-content h3 {
    font-size: 1.3rem;
    color: #2d5016;
    margin-bottom: 1rem;
    font-family: 'jf-lanyangming', 'Noto Serif TC', serif;
  }

  .stats {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }

  .stat-item {
    text-align: center;
    padding: 1rem;
    background: #f9fafb;
    border-radius: 8px;
  }

  .stat-number {
    display: block;
    font-size: 1.8rem;
    font-weight: 700;
    color: #16a34a;
  }

  .stat-label {
    font-size: 0.85rem;
    color: #6b7280;
  }

  .category-distribution h4 {
    font-size: 1rem;
    margin-bottom: 0.75rem;
    color: #374151;
  }

  .category-list {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .category-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.85rem;
  }

  .category-color {
    width: 12px;
    height: 12px;
    border-radius: 50%;
  }

  .panel-links {
    margin-top: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .panel-link {
    padding: 0.75rem;
    background: #f3f4f6;
    border-radius: 8px;
    text-decoration: none;
    color: #374151;
    font-weight: 500;
    text-align: center;
    transition: background 0.2s;
  }

  .panel-link:hover {
    background: #e5e7eb;
  }

  .article-content {
    animation: fadeIn 0.3s ease;
  }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .back-btn {
    background: none;
    border: none;
    color: #6b7280;
    cursor: pointer;
    font-size: 0.9rem;
    margin-bottom: 1rem;
    padding: 0.5rem 0;
  }

  .back-btn:hover {
    color: #16a34a;
  }

  .article-meta {
    margin-bottom: 1rem;
  }

  .article-category {
    display: inline-block;
    padding: 0.25rem 0.75rem;
    background: #f0fdf4;
    color: #16a34a;
    border-radius: 20px;
    font-size: 0.8rem;
    font-weight: 500;
  }

  .read-more-btn {
    display: inline-block;
    margin-top: 1rem;
    padding: 0.75rem 1.5rem;
    background: #16a34a;
    color: white;
    text-decoration: none;
    border-radius: 8px;
    font-weight: 500;
    transition: background 0.2s;
  }

  .read-more-btn:hover {
    background: #15803d;
  }

  @media (max-width: 1024px) {
    .controls-inner {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }
    
    .map-body {
      grid-template-columns: 1fr;
    }
    
    .map-panel {
      position: relative;
      top: auto;
    }
  }

  @media (max-width: 768px) {
    .map-hero h1 {
      font-size: 2.2rem;
    }
    
    .filter-buttons {
      justify-content: center;
    }
    
    .filter-btn {
      font-size: 0.8rem;
      padding: 0.4rem 0.8rem;
    }
  }
</style>

<script>
  // Category colors mapping
  const categoryColors = {
    history: '#e74c3c',
    geography: '#2ecc71', 
    culture: '#9b59b6',
    food: '#f39c12',
    art: '#e91e63',
    music: '#00bcd4',
    technology: '#3498db',
    nature: '#27ae60',
    people: '#ff9800',
    society: '#607d8b',
    economy: '#ff5722',
    lifestyle: '#8bc34a'
  };

  const categoryNames = {
    history: '📜 歷史',
    geography: '🗺️ 地理', 
    culture: '🎭 文化',
    food: '🍜 美食',
    art: '🎨 藝術',
    music: '🎵 音樂',
    technology: '💻 科技',
    nature: '🌿 自然',
    people: '👥 人物',
    society: '⚖️ 社會',
    economy: '📈 經濟',
    lifestyle: '🏮 生活'
  };

  let activeRegionFilter = 'all';
  let activeCategoryFilter = 'all';

  // Initialize map
  function initMap() {
    const markers = document.querySelectorAll('.marker');
    const tooltip = document.getElementById('tooltip');
    const regionFilters = document.getElementById('regionFilters');
    const categoryFilters = document.getElementById('categoryFilters');

    // Set up marker colors based on category
    markers.forEach(marker => {
      const category = marker.dataset.category;
      if (categoryColors[category]) {
        marker.setAttribute('fill', categoryColors[category]);
      }
    });

    // Marker hover events
    markers.forEach(marker => {
      marker.addEventListener('mouseenter', (e) => {
        const title = e.target.dataset.title;
        const category = e.target.dataset.category;
        const desc = e.target.dataset.desc;
        
        tooltip.querySelector('.tooltip-title').textContent = title;
        tooltip.querySelector('.tooltip-category').textContent = categoryNames[category] || category;
        tooltip.querySelector('.tooltip-desc').textContent = desc;
        
        tooltip.style.opacity = '1';
      });

      marker.addEventListener('mousemove', (e) => {
        const rect = e.target.closest('svg').getBoundingClientRect();
        tooltip.style.left = (e.clientX - rect.left + 10) + 'px';
        tooltip.style.top = (e.clientY - rect.top - 10) + 'px';
      });

      marker.addEventListener('mouseleave', () => {
        tooltip.style.opacity = '0';
      });

      marker.addEventListener('click', (e) => {
        showArticleInfo(e.target);
      });
    });

    // Region filter buttons
    regionFilters.addEventListener('click', (e) => {
      if (e.target.classList.contains('filter-btn')) {
        regionFilters.querySelectorAll('.filter-btn').forEach(btn => btn.classList.remove('active'));
        e.target.classList.add('active');
        activeRegionFilter = e.target.dataset.filter;
        applyFilters();
      }
    });

    // Category filter buttons
    categoryFilters.addEventListener('click', (e) => {
      if (e.target.classList.contains('filter-btn')) {
        categoryFilters.querySelectorAll('.filter-btn').forEach(btn => btn.classList.remove('active'));
        e.target.classList.add('active');
        activeCategoryFilter = e.target.dataset.filter;
        applyFilters();
      }
    });

    // Back button
    document.getElementById('backBtn').addEventListener('click', () => {
      document.getElementById('defaultContent').style.display = 'block';
      document.getElementById('articleContent').style.display = 'none';
    });
  }

  function applyFilters() {
    const markers = document.querySelectorAll('.marker');
    let visibleCount = 0;
    
    markers.forEach(marker => {
      const region = marker.dataset.region;
      const category = marker.dataset.category;
      
      const regionMatch = activeRegionFilter === 'all' || region === activeRegionFilter;
      const categoryMatch = activeCategoryFilter === 'all' || category === activeCategoryFilter;
      
      if (regionMatch && categoryMatch) {
        marker.classList.remove('hidden');
        visibleCount++;
      } else {
        marker.classList.add('hidden');
      }
    });

    // Update stats
    document.getElementById('totalMarkers').textContent = visibleCount;
  }

  function showArticleInfo(marker) {
    const title = marker.dataset.title;
    const category = marker.dataset.category;
    const desc = marker.dataset.desc;
    const link = marker.dataset.link;

    document.getElementById('articleTitle').textContent = title;
    document.getElementById('articleCategory').textContent = categoryNames[category];
    document.getElementById('articleDesc').textContent = desc;
    document.getElementById('articleLink').href = link;

    // Set category color
    const categoryEl = document.getElementById('articleCategory');
    categoryEl.style.background = categoryColors[category] + '20';
    categoryEl.style.color = categoryColors[category];

    document.getElementById('defaultContent').style.display = 'none';
    document.getElementById('articleContent').style.display = 'block';
  }

  // Initialize when page loads
  document.addEventListener('DOMContentLoaded', initMap);
</script>
</Layout>