<style>
  .resources-page {
    min-height: 100vh;
    background: linear-gradient(135deg, #f8fafc 0%, #e2e8f0 100%);
    font-family: 'jf-jinxuanlatte', 'Noto Sans TC', sans-serif;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 2rem;
  }

  /* Hero Section */
  .hero {
    text-align: center;
    margin-bottom: 3rem;
    padding: 4rem 0;
  }

  /* Resources Mindmap */
  .resources-mindmap {
    margin-top: 3rem;
    padding: 2rem;
    background: linear-gradient(135deg, #ecfdf5 0%, #d1fae5 50%, #a7f3d0 100%);
    border-radius: 16px;
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
  }

  #resources-graph {
    overflow: visible;
    width: 100%;
    max-width: 1400px;
    margin: 0 auto;
    height: auto;
    min-height: 700px;
    border-radius: 12px;
    background: rgba(255, 255, 255, 0.3);
    backdrop-filter: blur(10px);
    position: relative;
    overflow: hidden;
  }

  .hero-title {
    font-size: 3.5rem;
    font-weight: 900;
    background: linear-gradient(135deg, #065f46, #059669, #10b981);
    background-clip: text;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    margin-bottom: 1rem;
    letter-spacing: -0.02em;
  }

  .hero-subtitle {
    font-size: 1.3rem;
    color: #64748b;
    line-height: 1.7;
    max-width: 600px;
    margin: 0 auto;
  }

  /* Breadcrumb */
  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 3rem;
    font-size: 0.95rem;
    color: #64748b;
  }

  .breadcrumb a {
    color: #059669;
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .breadcrumb a:hover {
    color: #065f46;
  }

  .separator {
    color: #94a3b8;
  }

  .current {
    font-weight: 600;
    color: #374151;
  }

  /* Section Styling */
  .core-header,
  .more-header {
    margin: 4rem 0 2rem;
    padding-bottom: 1rem;
    border-bottom: 2px solid #e2e8f0;
  }
  .core-header h2,
  .more-header h2 {
    font-size: 2rem;
    color: #065f46;
    margin-bottom: 0.5rem;
  }
  .resource-section h3 {
    font-size: 1.25rem;
    color: #475569;
    margin-bottom: 1.5rem;
    padding-left: 0.75rem;
    border-left: 4px solid #065f46;
  }
  .resource-section {
    margin-bottom: 4rem;
  }

  .resource-section h2 {
    font-family: 'jf-jinxuanlatte', 'Noto Sans TC', sans-serif;
    font-size: 2.2rem;
    font-weight: 700;
    color: #065f46;
    margin-bottom: 1rem;
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .section-desc {
    font-size: 1.1rem;
    color: #64748b;
    margin-bottom: 2rem;
    line-height: 1.6;
  }

  /* Site Grid */
  .site-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.5rem;
  }

  .site-card {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 1.25rem;
    background: white;
    border-radius: 12px;
    box-shadow: 0 2px 4px -1px rgba(0, 0, 0, 0.06);
    border: 1px solid #e5e7eb;
    text-decoration: none;
    transition: all 0.3s ease;
  }

  .site-card:hover {
