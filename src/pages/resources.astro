<script is:inline src="https://d3js.org/d3.v7.min.js"></script>
<script is:inline define:vars={{ mindmapData }}>
  document.addEventListener('DOMContentLoaded', function () {
    const container = document.getElementById('resources-graph');
    if (!container) return;

    const data = JSON.parse(mindmapData);

    // Build hierarchy from flat data
    const categories = [];
    const catMap = {};
    data.nodes.forEach((n) => {
      if (n.group === 'center') return;
      if (n.size > 10) {
        const cat = { ...n, children: [] };
        catMap[n.id] = cat;
        categories.push(cat);
      }
    });
    data.nodes.forEach((n) => {
      if (n.size <= 10 && n.group !== 'center') {
        const parentId = n.id.split('_')[0];
        if (catMap[parentId]) catMap[parentId].children.push(n);
      }
    });

    // Split categories: half left, half right
    const half = Math.ceil(categories.length / 2);
    const rightCats = categories.slice(0, half);
    const leftCats = categories.slice(half);

    const rightRoot = { id: 'r', label: '', children: rightCats };
    const leftRoot = { id: 'l', label: '', children: leftCats };

    // Layout params
    const dx = 22; // vertical spacing
    const dy = 160; // horizontal spacing - reduced to prevent stretching
    const treeLayout = d3.tree().nodeSize([dx, dy]);

    // Layout right tree
    const rightH = d3.hierarchy(rightRoot);
    treeLayout(rightH);

    // Layout left tree (mirror)
    const leftH = d3.hierarchy(leftRoot);
    treeLayout(leftH);
    // Mirror: negate y for left side
    leftH.each((d) => {
      d.y = -d.y;
    });

    // Collect all nodes and links (skip the fake roots)
    const allNodes = [];
    const allLinks = [];

    // Root node (center)
    const rootNode = {
      x: 0,
      y: 0,
      depth: 0,
      data: { id: 'taiwan', label: '🇹🇼 台灣資源', color: '#065f46' },
      _side: 'center',
    };
    allNodes.push(rootNode);

    // Right side
    rightH.each((d) => {
      if (d.depth === 0) return; // skip fake root
      d._side = 'right';
      allNodes.push(d);
    });
    rightH.links().forEach((link) => {
      if (link.source.depth === 0) {
        // Connect to center root instead
        allLinks.push({ source: rootNode, target: link.target });
      } else {
        allLinks.push(link);
      }
    });

    // Left side
    leftH.each((d) => {
      if (d.depth === 0) return;
      d._side = 'left';
      allNodes.push(d);
    });
    leftH.links().forEach((link) => {
      if (link.source.depth === 0) {
        allLinks.push({ source: rootNode, target: link.target });
      } else {
        allLinks.push(link);
      }
    });

    // Compute bounding box
    let x0 = -100,
      x1 = 100,
      y0 = -500,
      y1 = 500;
    allNodes.forEach((d) => {
      const nx = d.x || 0,
        ny = d.y || 0;
      if (nx < x0) x0 = nx;
      if (nx > x1) x1 = nx;
      if (ny < y0) y0 = ny;
      if (ny > y1) y1 = ny;
    });

    const width = container.clientWidth;
    const padding = 120;
    const svgW = y1 - y0 + padding * 2;
    const svgH = Math.max(700, x1 - x0 + padding * 2);
    const centerX = width / 2;
    const centerY = svgH / 2;

    const svg = d3
      .select('#resources-graph')
      .append('svg')
      .attr('width', width)
      .attr('height', svgH);

    const g = svg
      .append('g')
      .attr('transform', `translate(${centerX}, ${centerY})`);

    // Zoom + pan
    svg
      .call(
        d3
          .zoom()
          .scaleExtent([0.3, 2.5])
          .on('zoom', (event) => {
            g.attr('transform', event.transform);
          }),
      )
      .call(
        d3.zoom().transform,
        d3.zoomIdentity.translate(centerX, centerY).scale(0.9),
      );

    // Links — smooth horizontal bezier curves
    g.append('g')
      .attr('fill', 'none')
      .selectAll('path')
      .data(allLinks)
      .join('path')
      .attr('d', (d) => {
        const sy = d.source.y || 0,
          sx = d.source.x || 0;
        const ty = d.target.y || 0,
          tx = d.target.x || 0;

        const my = (sy + ty) / 2;
        return `M${sy},${sx} C${my},${sx} ${my},${tx} ${ty},${tx}`;
      })
      .attr('stroke', (d) => d.target.data.color || '#94a3b8')
      .attr('stroke-width', (d) => ((d.target.depth || 0) <= 1 ? 2 : 1.2))
      .attr('stroke-opacity', 0.5);

    // Nodes
    const nodeG = g
      .append('g')
      .selectAll('g')
      .data(allNodes)
      .join('g')
      .attr('transform', (d) => `translate(${d.y || 0},${d.x || 0})`)
      .attr('cursor', (d) => (d.data.url ? 'pointer' : 'default'));

    nodeG
      .append('circle')
      .attr('r', (d) => {
        if ((d.depth || 0) === 0) return 10;
        if ((d.depth || 0) === 1) return 6;
        return 3.5;
      })
      .attr('fill', (d) => d.data.color || '#94a3b8')
      .attr('stroke', '#fff')
      .attr('stroke-width', 1.5);

    // Labels — horizontal, positioned based on side
    nodeG
      .append('text')
      .attr('dy', '0.32em')
      .attr('x', (d) => {
        if ((d.depth || 0) === 0) return 0; // root: centered above
        if (d._side === 'left') {
          return d.children ? 10 : -8; // left side: leaves go left
        }
        return d.children ? -10 : 8; // right side: leaves go right
      })
      .attr('text-anchor', (d) => {
        if ((d.depth || 0) === 0) return 'middle';
        if (d._side === 'left') {
          return d.children ? 'start' : 'end';
        }
        return d.children ? 'end' : 'start';
      })
      .attr('font-size', (d) => {
        if ((d.depth || 0) === 0) return '14px';
        if ((d.depth || 0) === 1) return '12px';
        return '10px';
      })
      .attr('font-weight', (d) => ((d.depth || 0) <= 1 ? '700' : '400'))
      .attr('fill', (d) =>
        (d.depth || 0) === 0
          ? '#065f46'
          : (d.depth || 0) === 1
            ? '#1a1a1a'
            : '#555',
      )
      .text((d) => d.data.label || d.data.name || '');

    // Click to navigate
    nodeG.on('click', (event, d) => {
      if (d.data.url) {
        window.open(d.data.url, '_blank', 'noopener noreferrer');
      }
    });

    // Hover effects
    nodeG
      .on('mouseover', function () {
        d3.select(this)
          .select('circle')
          .transition()
          .duration(150)
          .attr('stroke', '#3b82f6')
          .attr('stroke-width', 3);
        d3.select(this)
          .select('text')
          .transition()
          .duration(150)
          .attr('fill', '#065f46')
          .attr('font-weight', '700');
      })
      .on('mouseout', function (event, d) {
        d3.select(this)
          .select('circle')
          .transition()
          .duration(150)
          .attr('stroke', '#fff')
          .attr('stroke-width', 1.5);
        d3.select(this)
          .select('text')
          .transition()
          .duration(150)
          .attr(
            'fill',
            (d.depth || 0) === 0
              ? '#065f46'
              : (d.depth || 0) === 1
                ? '#1a1a1a'
                : '#555',
          )
          .attr('font-weight', (d.depth || 0) <= 1 ? '700' : '400');
      });
  });
</script>
