---
import Layout from '../../layouts/Layout.astro';
import ProticoScript from '../../components/ProticoScript.astro';
---

<Layout
  title="I Want to Contribute — Taiwan.md"
  description="No programming skills needed. You can help the world understand Taiwan"
  lang="en"
>
  <div class="contribute-page">
    <section class="contribute-hero">
      <h1>I Want to Contribute ✋</h1>
      <p class="hero-sub">
        No programming skills needed. Your Taiwan stories are the most valuable
        content.
      </p>
      <p class="hero-note">
        Current website content is initially generated by AI, expecting everyone
        to join forces to make information more complete and accurate!<br />If
        you have any questions, please feel free to <a
          href="mailto:cheyu.wu@monoame.com"
          style="color: #ABC468;">contact us</a
        >. Thank you for your thoughtful feedback!
      </p>
    </section>

    <section class="how-it-works">
      <div class="how-inner">
        <h2>🗺️ First, understand how this website works</h2>
        <div class="how-grid">
          <div class="how-card">
            <h3>📁 Language Toggle</h3>
            <p>
              Toggle between <strong>Chinese</strong> and <strong
                >English</strong
              > in the top-right corner. Chinese is the primary content (SSOT), English
              is being translated continuously.
            </p>
            <code>taiwan.md/ → Chinese<br />taiwan.md/en/ → English</code>
          </div>
          <div class="how-card">
            <h3>📝 .md Button</h3>
            <p>
              The floating <strong>.md</strong> button in the bottom-right corner
              of each page shows the original Markdown file. All Taiwan.md content
              is plain text Markdown — that's where the .md domain comes from.
            </p>
          </div>
          <div class="how-card">
            <h3>🕸️ Knowledge Graph</h3>
            <p>
              The "Graph" link in the navigation leads to an interactive
              knowledge network diagram. Drag to explore connections between 12
              aspects.
            </p>
          </div>
          <div class="how-card">
            <h3>🤖 AI-Friendly</h3>
            <p>
              All content is fully open to AI crawlers (<a href="/robots.txt"
                >robots.txt</a
              >, <a href="/llms.txt">llms.txt</a>). Feel free for ChatGPT /
              Claude / Gemini to cite.
            </p>
          </div>
        </div>
      </div>
    </section>

    <section class="roles-section">
      <div class="roles-inner">
        <h2>Your expertise is Taiwan's needed strength</h2>
        <p class="roles-desc">
          No matter your background, you can bring unique value to this
          knowledge base
        </p>
        <div class="roles-grid">
          <div class="role-card">
            <div class="role-icon">✍️</div>
            <h3>Writers / Editors</h3>
            <p>
              Your writing skills are the core of the knowledge base. Write new
              articles, improve readability of existing content, proofread typos
              and sentences.
            </p>
            <div class="role-actions">
              <span
                >→ Pick a topic you're familiar with and write a warm article</span
              >
              <span>→ Help polish existing articles and add details</span>
            </div>
          </div>

          <div class="role-card">
            <div class="role-icon">🔬</div>
            <h3>Researchers / Scholars</h3>
            <p>
              Your professional knowledge is a quality guarantee. Fact-check,
              add academic perspectives, point out common misconceptions.
            </p>
            <div class="role-actions">
              <span>→ Review facts and citations in articles</span>
              <span>→ Add in-depth content from your research field</span>
            </div>
          </div>

          <div class="role-card">
            <div class="role-icon">🎨</div>
            <h3>Designers</h3>
            <p>
              Good information needs good presentation. Infographics, SVG
              illustrations, and UI/UX improvements are all huge contributions.
            </p>
            <div class="role-actions">
              <span>→ Create infographics or diagrams for articles</span>
              <span
                >→ Contribute Taiwan-themed open source icons to <a
                  href="/en/assets">SVG Asset Library</a
                ></span
              >
            </div>
          </div>

          <div class="role-card">
            <div class="role-icon">💻</div>
            <h3>Engineers</h3>
            <p>
              The website itself needs evolution. Performance optimization, new
              features, i18n, accessibility, SEO are all welcome.
            </p>
            <div class="role-actions">
              <span
                >→ Check if there's anything you can solve in <a
                  href="https://github.com/frank890417/taiwan-md/issues"
                  target="_blank">GitHub Issues</a
                ></span
              >
              <span>→ Improve search, graph, multilingual features</span>
            </div>
          </div>

          <div class="role-card">
            <div class="role-icon">🌍</div>
            <h3>Translators</h3>
            <p>
              Help the world understand Taiwan. Chinese to English, Chinese to
              Japanese, or any language — every translation expands Taiwan's
              visibility.
            </p>
            <div class="role-actions">
              <span
                >→ Pick an article from <code>knowledge/</code> and translate to <code
                  >knowledge/en/</code
                ></span
              >
              <span>→ Japanese version is in planning, welcome to join</span>
            </div>
          </div>

          <div class="role-card">
            <div class="role-icon">📸</div>
            <h3>Photographers / Creators</h3>
            <p>
              A good photo is worth a thousand words. CC-licensed Taiwan photos,
              field recordings, and media materials are much needed.
            </p>
            <div class="role-actions">
              <span
                >→ Photograph Taiwan through your eyes, contribute with CC
                license</span
              >
              <span
                >→ Record Taiwan sounds, join the <a
                  href="https://github.com/frank890417/taiwan-md/tree/main/assets/sounds"
                  target="_blank">soundscape project</a
                ></span
              >
            </div>
          </div>

          <div class="role-card">
            <div class="role-icon">🏛️</div>
            <h3>Cultural Workers / Local Experts</h3>
            <p>
              Your local knowledge is something AI can never generate. Oral
              history, local stories, cultural contexts — these are the most
              valuable content.
            </p>
            <div class="role-actions">
              <span
                >→ Write down your hometown stories, the kind textbooks don't
                teach</span
              >
              <span>→ Correct local errors in articles</span>
            </div>
          </div>

          <div class="role-card">
            <div class="role-icon">📢</div>
            <h3>Anyone who cares about Taiwan</h3>
            <p>
              Even if none of the above fits you, your sharing is contribution
              itself. Forward to friends, mention on social media, give us
              feedback.
            </p>
            <div class="role-actions">
              <span
                >→ Share taiwan.md with friends who want to understand Taiwan</span
              >
              <span>→ See errors? Open an issue and tell us</span>
            </div>
          </div>
        </div>

        <div class="org-section">
          <h3 class="org-title">
            🏢 Institutions, Government Agencies & Companies
          </h3>
          <p class="org-desc">
            Taiwan.md welcomes various organizations to participate in different
            ways, jointly building Taiwan's digital knowledge infrastructure.
          </p>

          <div class="org-grid">
            <div class="org-card">
              <div class="org-icon">🏛️</div>
              <h4>Government Agencies / Public Sector</h4>
              <p>
                Provide official open data, statistics, policy documents. Help
                with fact-checking and content correction. License government
                publications or CC-licensed images.
              </p>
              <div class="org-example">
                Examples: Ministry of Culture, Tourism Bureau, Council of
                Indigenous Peoples, Ministry of Agriculture, Institute of
                History
              </div>
            </div>

            <div class="org-card">
              <div class="org-icon">🎓</div>
              <h4>Academic Institutions / Research Units</h4>
              <p>
                Help write or review articles in professional fields. Provide
                research data and academic perspectives. Recommend students to
                use Taiwan.md as an open knowledge practice field.
              </p>
              <div class="org-example">
                Examples: Academia Sinica, University Taiwan Studies
                Departments, Museums, Cultural Studios
              </div>
            </div>

            <div class="org-card">
              <div class="org-icon">🏢</div>
              <h4>Companies / Commercial Organizations</h4>
              <p>
                Sponsor operations (servers, translation, community events).
                Display branding as Gold / Silver / Bronze Sponsor. Encourage
                employees to participate as volunteers.
              </p>
              <div class="org-example">
                Examples: Tech companies, Publishers, Cultural foundations,
                International corporate CSR
              </div>
            </div>

            <div class="org-card">
              <div class="org-icon">🌏</div>
              <h4>NGO / International Organizations</h4>
              <p>
                Help with multilingual translation and international promotion.
                Provide local perspectives on human rights, environment, social
                issues. Use Taiwan.md as international education resource.
              </p>
              <div class="org-example">
                Examples: Taiwan Foundation for Democracy, Cultural exchange
                associations, Overseas Taiwanese communities
              </div>
            </div>
          </div>

          <div class="org-contact">
            <p><strong>Partnership Contact:</strong></p>
            <p>
              📧 <a href="mailto:cheyu.wu@monoame.com">cheyu.wu@monoame.com</a>
            </p>
            <p>
              Please include "Taiwan.md Partnership — [Organization Name]" in
              subject line
            </p>
            <p class="org-note">
              We will respond within 3 business days. Any form of partnership
              proposal is welcome.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- New Writing Guidelines Section -->
    <section class="writing-guides">
      <div class="guides-inner">
        <h2>📖 Complete Contribution Guide</h2>
        <p class="guides-desc">
          No matter your background and expertise, we have the most suitable
          contribution method for you
        </p>

        <div class="guides-grid">
          <div class="guide-card writing">
            <div class="guide-icon">✍️</div>
            <h3>How to Write a Good Article</h3>
            <div class="guide-content">
              <h4>📐 Structure Suggestions</h4>
              <ul>
                <li>
                  <strong>Title:</strong> Clear and powerful, avoid too long (e.g.:
                  Taiwan Night Market Culture)
                </li>
                <li>
                  <strong>Opening:</strong> One sentence explaining what this is and
                  why it's important
                </li>
                <li>
                  <strong>Body:</strong> Support with stories, data, and examples
                </li>
                <li>
                  <strong>Ending:</strong> Summarize significance or provide related
                  links
                </li>
              </ul>

              <h4>📝 Format Guidelines</h4>
              <ul>
                <li>
                  Use <code>##</code> for sections, <code>###</code> for subsections
                </li>
                <li>Important terms in <code>**bold**</code></li>
                <li>Quotes use <code>> Quote text</code></li>
                <li>
                  Lists use <code>- item</code> or <code>1. numbered</code>
                </li>
                <li>Link format: <code>[Link text](URL)</code></li>
              </ul>

              <h4>💡 Example Paragraph</h4>
              <pre><code>## Origins of Night Markets

Taiwan's night market culture originated from **temple fairs during the Qing Dynasty**. Initially, vendors would gather at temple festivals to sell various snacks and daily goods.

> "First府, second鹿, third艋舺" in the ancient Taiwanese saying, each place had its own unique market culture.

Today's most famous night markets include:
- **Shilin Night Market** (Taipei)
- **Fengjia Night Market** (Taichung)  
- **Liuhe Night Market** (Kaohsiung)

[Learn more about night market culture](/en/food/night-markets)</code></pre>
            </div>
          </div>

          <div class="guide-card ai">
            <div class="guide-icon">🤖</div>
            <h3>AI-Assisted Contribution</h3>
            <div class="guide-content">
              <h4>📋 Complete Prompt Template</h4>
              <div class="ai-prompt-box">
                <code
                  >I want to contribute content to Taiwan.md (https://taiwan.md)
                  open Taiwan knowledge base. Please first: 1. Read
                  https://taiwan.md/llms.txt to understand project structure 2.
                  Read https://taiwan.md/contributing to understand editorial
                  guidelines 3. Browse existing article categories and writing
                  styles Then guide me through the following process: 1. Confirm
                  my topic: [Your topic] 2. Check if there are related articles
                  to avoid duplication 3. Plan article structure and outline 4.
                  Help me write in Markdown format according to guidelines 5.
                  Suggest appropriate category tags and related links 6. Check
                  content accuracy and neutral viewpoint My knowledge
                  background: [Describe your expertise] Topic I want to write:
                  [Specific topic, e.g.: Taiwan coffee culture development
                  history]</code
                >
                <button
                  class="copy-btn"
                  onclick="navigator.clipboard.writeText(this.previousElementSibling.textContent).then(()=>this.textContent='✅ Copied')"
                  >📋 Copy</button
                >
              </div>

              <h4>🎯 Professional Field AI Prompts</h4>
              <ul>
                <li>
                  <strong>Historians:</strong> "Help me fact-check this Taiwan history
                  from multiple historical perspectives"
                </li>
                <li>
                  <strong>Cultural workers:</strong> "Help me introduce this Taiwan
                  cultural phenomenon from an international perspective"
                </li>
                <li>
                  <strong>Technical experts:</strong> "Help me explain Taiwan's technological
                  development in non-technical language"
                </li>
                <li>
                  <strong>Local residents:</strong> "Help me organize hometown stories
                  into structured articles"
                </li>
              </ul>
            </div>
          </div>

          <div class="guide-card translation">
            <div class="guide-icon">🌍</div>
            <h3>Translation Guide</h3>
            <div class="guide-content">
              <h4>🎯 Chinese→English Translation Key Points</h4>
              <ul>
                <li>
                  <strong>Cultural terms:</strong> Keep original with annotation (e.g.:
                  <em>jiufen (九份)</em>)
                </li>
                <li>
                  <strong>Proper nouns:</strong> Use consistent official English names
                </li>
                <li>
                  <strong>Food names:</strong> Transliteration + explanation (<em
                    >xiaolongbao (soup dumplings)</em
                  >)
                </li>
                <li>
                  <strong>Historical events:</strong> Use internationally recognized
                  English names
                </li>
              </ul>

              <h4>⚠️ Fact Checking (Required)</h4>
              <p>
                All articles must be fact-checked before merging. AI-assisted
                content is especially prone to errors (species distribution,
                person nationality, awards, works, etc.).
              </p>
              <ul>
                <li>
                  Each article must have a <strong>References</strong> section at
                  the end
                </li>
                <li>
                  Numbers must cite <strong>source institution + year</strong>
                </li>
                <li>
                  Source priority: Official government > Academic research >
                  Authoritative media > Professional institutions
                </li>
                <li>
                  Found errors? Welcome to submit PR corrections directly!
                </li>
              </ul>

              <h4>📚 Reference Resources</h4>
              <ul>
                <li>
                  <a href="http://www.taiwan.gov.tw/" target="_blank"
                    >Taiwan.gov.tw</a
                  > - Official terminology
                </li>
                <li>
                  <a href="https://www.mofa.gov.tw/en/" target="_blank"
                    >Ministry of Foreign Affairs English</a
                  > - Political terms
                </li>
                <li>
                  <a
                    href="https://www.taiwan.net.tw/m1.aspx?sNo=0001019"
                    target="_blank">Tourism Bureau</a
                  > - Place names and attractions
                </li>
              </ul>

              <h4>⚠️ Translation Considerations</h4>
              <ul>
                <li>Maintain neutral and objective narrative</li>
                <li>Avoid overly localized expressions</li>
                <li>Sensitive political topics require special caution</li>
                <li>
                  Numbers and date formats should follow international
                  conventions
                </li>
              </ul>
            </div>
          </div>

          <div class="guide-card images">
            <div class="guide-icon">📸</div>
            <h3>Image Guidelines</h3>
            <div class="guide-content">
              <h4>✅ Acceptable Image Sources</h4>
              <ul>
                <li>
                  <strong>Wikimedia Commons:</strong> Preferred, lots of Taiwan-related
                  CC-licensed images
                </li>
                <li>
                  <strong>Self-taken:</strong> Best choice, remember to declare original
                </li>
                <li>
                  <strong>Government open data:</strong> Most can be used freely
                </li>
                <li>
                  <strong>CC-licensed images:</strong> Must cite source and license
                  type
                </li>
              </ul>

              <h4>🔍 Recommended Resources</h4>
              <ul>
                <li>
                  <a
                    href="https://commons.wikimedia.org/wiki/Category:Taiwan"
                    target="_blank">Wikimedia Taiwan Category</a
                  >
                </li>
                <li>
                  <a href="https://data.gov.tw/" target="_blank"
                    >Government Data Open Platform</a
                  >
                </li>
                <li>
                  <a href="https://unsplash.com/s/photos/taiwan" target="_blank"
                    >Unsplash Taiwan</a
                  >
                </li>
                <li>
                  <a
                    href="https://www.pexels.com/search/taiwan/"
                    target="_blank">Pexels Taiwan</a
                  >
                </li>
              </ul>

              <h4>📝 Usage Format</h4>
              <pre><code>![Image description](image link)

*Image caption text*
*Source: [Wikimedia Commons](link) / CC BY-SA 4.0*</code></pre>

              <h4>❌ Cannot Use</h4>
              <ul>
                <li>Random images from Google image search</li>
                <li>Unlicensed commercial photography</li>
                <li>Photos from others' social media</li>
                <li>Historical photos with unclear copyright</li>
              </ul>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="paths">
      <div class="paths-inner">
        <h2>Choose your way</h2>
        <div class="path-grid">
          <div class="path-card easy">
            <div class="path-badge">🟢 Easiest</div>
            <h3>Just fill out a form</h3>
            <p>
              Write down what you know. A story, a fun fact, the origin of a
              dish.<br />We'll help with formatting, translation, and
              publishing.
            </p>
            <ul>
              <li>✅ No account needed</li>
              <li>✅ No need to know Markdown</li>
              <li>✅ Can upload photos and documents</li>
              <li>✅ Anonymous or credited, your choice</li>
            </ul>
            <a href="#form" class="path-btn primary">Start filling ↓</a>
          </div>

          <div class="path-card medium">
            <div class="path-badge">🟡 Some barrier</div>
            <h3>Send it to us</h3>
            <p>
              Already have existing articles, PDFs, or photos? Send them
              directly.
            </p>
            <ul>
              <li>
                📧 Email: <a href="mailto:cheyu.wu@monoame.com"
                  >cheyu.wu@monoame.com</a
                >
              </li>
              <li>💬 GitHub Discussion (Chinese OK)</li>
            </ul>
            <a
              href="mailto:cheyu.wu@monoame.com?subject=Taiwan.md Content Contribution"
              class="path-btn secondary">Send Email →</a
            >
          </div>

          <div class="path-card ai">
            <div class="path-badge">🤖 Let AI help you</div>
            <h3>Talk to your AI</h3>
            <p>
              Paste the following to ChatGPT, Claude, or Gemini, and your AI
              will guide you step by step to complete your contribution:
            </p>
            <div class="ai-prompt">
              <code
                >I want to contribute content to Taiwan.md (taiwan.md) open
                Taiwan knowledge base. Please first read
                https://taiwan.md/llms.txt and https://taiwan.md/contributing to
                understand the project structure and editorial guidelines, then
                guide me step by step to turn my Taiwan knowledge into a
                Markdown article. The topic I want to write about is: ______</code
              >
              <button
                class="copy-btn"
                onclick="navigator.clipboard.writeText(this.previousElementSibling.textContent).then(()=>this.textContent='✅ Copied')"
                >📋 Copy</button
              >
            </div>
            <ul>
              <li>✅ No programming skills needed</li>
              <li>✅ AI will help format into Markdown</li>
              <li>✅ Can submit via Email or PR after completion</li>
              <li>✅ Supports any AI assistant</li>
            </ul>
          </div>

          <div class="path-card dev">
            <div class="path-badge">🔴 Developers</div>
            <h3>Fork & PR</h3>
            <p>
              You know Git? Great. Just add articles directly in the <code
                >knowledge/</code
              > directory.
            </p>
            <ul>
              <li>📖 <a href="/en/contributing">Contributing Guidelines</a></li>
              <li>
                📝 <a
                  href="https://github.com/frank890417/taiwan-md/blob/main/EDITORIAL.md"
                  target="_blank">Editorial Guidelines</a
                >
              </li>
            </ul>
            <a
              href="https://github.com/frank890417/taiwan-md"
              target="_blank"
              class="path-btn secondary">Go to GitHub →</a
            >
          </div>
        </div>
      </div>
    </section>

    <section class="form-section" id="form">
      <div class="form-inner">
        <h2>📝 Share your Taiwan knowledge</h2>
        <p class="form-desc">
          Fill in as much or as little as you want. One sentence is fine, a
          whole article is great. We'll take care of turning it into a beautiful
          article.
        </p>

        <form id="contribute-form">
          <div class="form-group">
            <label for="content"
              >What do you want to share? <span class="required">*</span></label
            >
            <textarea
              id="content"
              name="entry.content"
              rows="8"
              required
              placeholder="A story, a fun fact, the origin of a dish, the history of a place... anything goes.

For example: 'My grandma is from Changhua, she said that every Mid-Autumn Festival...'"
            ></textarea>
          </div>

          <div class="form-group">
            <label for="category">Which aspect does this belong to?</label>
            <select id="category" name="entry.category">
              <option value="">Not sure (we'll categorize it)</option>
              <option value="history">📜 History</option>
              <option value="geography">🗺️ Geography</option>
              <option value="culture">🎭 Culture</option>
              <option value="food">🍜 Food</option>
              <option value="art">🎨 Art</option>
              <option value="music">🎵 Music</option>
              <option value="technology">💻 Technology</option>
              <option value="nature">🌿 Nature</option>
              <option value="people">👥 People</option>
              <option value="society">⚖️ Society</option>
              <option value="economy">📈 Economy</option>
              <option value="lifestyle">🏠 Lifestyle</option>
            </select>
          </div>

          <div class="form-row">
            <div class="form-group">
              <label for="source-type">How do you know this?</label>
              <select id="source-type" name="entry.source_type">
                <option value="">Choose...</option>
                <option value="experience">Personal experience</option>
                <option value="family">Family oral history</option>
                <option value="book">Books</option>
                <option value="internet">Internet</option>
                <option value="professional">Professional background</option>
                <option value="other">Other</option>
              </select>
            </div>
            <div class="form-group">
              <label for="source-ref">Reference source</label>
              <input
                type="text"
                id="source-ref"
                name="entry.source_ref"
                placeholder="Link, book title, or any clue"
              />
            </div>
          </div>

          <div class="form-row">
            <div class="form-group">
              <label for="name">Your name</label>
              <input
                type="text"
                id="name"
                name="entry.name"
                placeholder="Fill if you want to be credited; leave blank for 'Anonymous Contributor'"
              />
            </div>
            <div class="form-group">
              <label for="email">Contact info</label>
              <input
                type="email"
                id="email"
                name="entry.email"
                placeholder="Email (if we need to confirm details with you)"
              />
            </div>
          </div>

          <button type="submit" class="submit-btn" id="submit-btn"
            >Submit Contribution 🚀</button
          >
        </form>

        <div id="success-msg" class="success-msg" style="display:none;">
          <span class="success-icon">🎉</span>
          <h3>Thank you for your contribution!</h3>
          <p>
            We received it. We'll organize it into an article as soon as
            possible and notify you when it's published (if you left an email).
          </p>
          <a href="/en" class="back-link">← Back to homepage to explore more</a>
        </div>

        <script is:inline>
          document
            .getElementById('contribute-form')
            .addEventListener('submit', async function (e) {
              e.preventDefault();
