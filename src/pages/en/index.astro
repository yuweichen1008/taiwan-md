---
import Layout from '../../layouts/Layout.astro';
import CategoryGrid from '../../components/CategoryGrid.astro';
import { getCollection } from 'astro:content';
import { readdir, readFile } from 'fs/promises';
import { resolve, join, basename } from 'path';
import matter from 'gray-matter';
// Fetch recent commits from GitHub API (works in shallow clone CI/CD environments)
let recentCommits: { hash: string; date: string; message: string }[] = [];
try {
  const res = await fetch(
    'https://api.github.com/repos/frank890417/taiwan-md/commits?per_page=5',
  );
  if (res.ok) {
    const data = await res.json();
    recentCommits = data.map((c: any) => ({
      hash: c.sha,
      date: c.commit.author.date,
      message: c.commit.message.split('\n')[0],
    }));
  }
} catch (e) {
  // silently fail
}

function commitIcon(msg: string) {
  if (msg.startsWith('feat')) return '✨';
  if (msg.startsWith('fix')) return '🐛';
  if (msg.startsWith('content')) return '📝';
  if (msg.startsWith('docs')) return '📖';
  return '📌';
}

function timeAgo(dateStr: string) {
  const now = new Date();
  const then = new Date(dateStr);
  const diff = Math.floor((now.getTime() - then.getTime()) / 1000);
  if (diff < 3600) return `${Math.floor(diff / 60)}m ago`;
  if (diff < 86400) return `${Math.floor(diff / 3600)}h ago`;
  if (diff < 604800) return `${Math.floor(diff / 86400)}d ago`;
  return then.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
}

// Count articles per category for English content
const categories = [
  { id: 'history', name: 'History', emoji: '📜' },
  { id: 'geography', name: 'Geography', emoji: '🗺️' },
  { id: 'culture', name: 'Culture', emoji: '🎭' },
  { id: 'food', name: 'Food', emoji: '🍜' },
  { id: 'art', name: 'Art', emoji: '🎨' },
  { id: 'music', name: 'Music', emoji: '🎵' },
  { id: 'technology', name: 'Technology', emoji: '💻' },
  { id: 'nature', name: 'Nature', emoji: '🌿' },
  { id: 'people', name: 'People', emoji: '👥' },
  { id: 'society', name: 'Society', emoji: '⚖️' },
  { id: 'economy', name: 'Economy', emoji: '📈' },
  { id: 'lifestyle', name: 'Lifestyle', emoji: '🏠' },
];

// Get English articles count and prepare random discovery list
const articleCounts: Record<string, number> = {};
let allArticles: { title: string; url: string; category: string }[] = [];

const categoryMapping: Record<string, string> = {
  history: 'History',
  geography: 'Geography',
  culture: 'Culture',
  food: 'Food',
  art: 'Art',
  music: 'Music',
  technology: 'Technology',
  nature: 'Nature',
  people: 'People',
  society: 'Society',
  economy: 'Economy',
  lifestyle: 'Lifestyle',
};

for (const cat of categories) {
  const folderName = categoryMapping[cat.id];
  try {
    const folderPath = resolve(process.cwd(), 'knowledge', 'en', folderName);
    const files = await readdir(folderPath);
    const mdFiles = files.filter(
      (f) => f.endsWith('.md') && !f.startsWith('_'),
    );
    articleCounts[cat.id] = mdFiles.length;

    for (const file of mdFiles) {
      const content = await readFile(join(folderPath, file), 'utf-8');
      const { data: frontmatter } = matter(content);
      const slug = basename(file, '.md');
      allArticles.push({
        title: frontmatter.title || slug,
        url: `/en/${cat.id}/${slug}`,
        category: cat.name,
      });
    }
  } catch {
    articleCounts[cat.id] = 0;
  }
}

const randomArticlesData = JSON.stringify(allArticles);
---

<Layout
  title="Taiwan.md - Open Knowledge Base of Taiwan"
  description="The open-source, AI-friendly knowledge base about Taiwan. Curated perspectives from people who love Taiwan, for everyone - humans and AI alike."
  lang="en"
>
  <section class="hero">
    <div class="hero-bg">
