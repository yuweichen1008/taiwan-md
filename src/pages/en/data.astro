---
import Layout from '../../layouts/Layout.astro';

const categories = [
  {
    icon: '📊',
    title: 'Government Open Data',
    description: 'Structured datasets and statistical platforms released by government agencies',
    items: [
      { name: 'Government Open Data Platform', url: 'https://data.gov.tw/', desc: 'Central open data portal with tens of thousands of datasets' },
      { name: 'DGBAS Statistical Database', url: 'https://statdb.dgbas.gov.tw/', desc: 'Population, economy, price indices and core national statistics' },
      { name: 'CEC Election Database', url: 'https://db.cec.gov.tw/', desc: 'Historical election results and voting data' },
      { name: 'Laws & Regulations Database', url: 'https://law.moj.gov.tw/', desc: 'Full-text search of all laws, orders, and judicial precedents' },
      { name: 'Air Quality Monitoring Network', url: 'https://airtw.moenv.gov.tw/', desc: 'Real-time AQI and PM2.5 monitoring data' },
    ]
  },
  {
    icon: '🗺️',
    title: 'Interactive Maps & Visualization',
    description: 'Real-time monitoring, geographic data, and environmental visualization tools',
    items: [
      { name: 'Taiwan Submarine Cable Map', url: 'https://smc.peering.tw/', desc: 'Community-built real-time submarine cable monitoring — a civic tech exemplar' },
      { name: 'NLSC Map Service', url: 'https://maps.nlsc.gov.tw/', desc: 'National land survey maps, aerial photos, and cadastral data' },
      { name: 'Seismological Center', url: 'https://scweb.cwa.gov.tw/', desc: 'Real-time earthquake information and historical records' },
      { name: 'WRA Disaster Prevention', url: 'https://fhy.wra.gov.tw/', desc: 'Real-time water levels, river monitoring, and reservoir data' },
      { name: 'Environmental Monitoring', url: 'https://env.gov.tw/', desc: 'Air quality, UV index, and water quality real-time monitoring' },
    ]
  },
  {
    icon: '🤖',
    title: 'Civic Tech',
    description: 'Open source communities, fact-checking, and digital democracy tools',
    items: [
      { name: 'g0v (gov-zero)', url: 'https://g0v.tw/', desc: "Taiwan's largest open-source civic tech community" },
      { name: 'g0v Hackathon Events', url: 'https://g0v-jothon.kktix.cc/', desc: 'Bimonthly hackathons and open data community events' },
      { name: 'Cofacts', url: 'https://cofacts.tw/', desc: 'Collaborative fact-checking chatbot for messaging apps' },
      { name: 'vTaiwan', url: 'https://vtaiwan.tw/', desc: 'Digital democracy platform for public policy deliberation' },
      { name: 'JOIN Platform', url: 'https://join.gov.tw/', desc: 'Government proposals, petitions, and policy discussions' },
    ]
  },
  {
    icon: '📰',
    title: 'Data Journalism & Fact-Checking',
    description: 'Investigative reporting, fact-checking organizations, and data-driven media',
    items: [
      { name: 'The Reporter', url: 'https://www.twreporter.org/', desc: "Taiwan's leading non-profit investigative journalism outlet" },
      { name: 'Taiwan FactCheck Center', url: 'https://tfc-taiwan.org.tw/', desc: 'IFCN-certified fact-checking organization' },
      { name: 'READr', url: 'https://www.readr.tw/', desc: 'Data journalism and open data visualization' },
      { name: 'ARTouch', url: 'https://artouch.com/', desc: "Taiwan's premier art news and criticism platform" },
    ]
  },
  {
    icon: '🔬',
    title: 'Academic & Research',
    description: 'Digital archives, ecological data, and AI training corpora',
    items: [
      { name: 'Academia Sinica Open Museum', url: 'https://openmuseum.tw/', desc: 'Digital archives and online curation' },
      { name: 'National Cultural Memory Bank', url: 'https://tcmb.culture.tw/', desc: 'Digital preservation of Taiwanese cultural memory' },
      { name: 'Taiwan Biodiversity Network', url: 'https://tbn.biodiv.tw/', desc: 'Species distribution and ecological observation data' },
      { name: 'TAIC — Taiwan AI Corpus', url: 'https://huggingface.co/TAIDE', desc: "Taiwan's sovereign AI training dataset" },
    ]
  },
];
---

<Layout
  title="Open Data & Civic Tech - Taiwan.md"
  description="A curated collection of Taiwan's open data platforms, civic tech tools, interactive maps, and digital resources"
>
  <div class="data-page">
    <div class="container">
      <!-- Hero -->
      <section class="hero">
        <h1 class="hero-title">Taiwan Open Data & Civic Tech</h1>
        <p class="hero-subtitle">
          From government open data to civic tech communities — explore Taiwan's digital public resources
        </p>
      </section>

      <!-- Categories -->
      <div class="categories">
        {categories.map(cat => (
          <section class="category-card">
            <div class="category-header">
              <span class="category-icon">{cat.icon}</span>
              <div>
                <h2 class="category-title">{cat.title}</h2>
                <p class="category-desc">{cat.description}</p>
              </div>
            </div>
            <ul class="item-list">
              {cat.items.map(item => (
                <li class="item">
                  <a href={item.url} target="_blank" rel="noopener noreferrer" class="item-link">
                    {item.name}
                  </a>
                  <span class="item-desc">— {item.desc}</span>
                </li>
              ))}
            </ul>
          </section>
        ))}
      </div>

      <!-- Back link -->
      <div class="back-link">
        <a href="/en/resources" class="btn-back">← Back to Resources</a>
      </div>
    </div>
  </div>
</Layout>

<style>
  .data-page {
    min-height: 100vh;
    background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%);
    color: #e2e8f0;
  }

  .container {
    max-width: 960px;
    margin: 0 auto;
    padding: 2rem;
  }

  .hero {
    text-align: center;
    padding: 4rem 0 3rem;
  }

  .hero-title {
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 900;
    background: linear-gradient(135deg, #38bdf8, #818cf8, #c084fc);
    background-clip: text;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    margin-bottom: 1rem;
  }

  .hero-subtitle {
    font-size: 1.15rem;
    color: #94a3b8;
    line-height: 1.7;
    max-width: 540px;
    margin: 0 auto;
  }

  .categories {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .category-card {
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 16px;
    padding: 2rem;
    transition: border-color 0.2s ease;
  }

  .category-card:hover {
    border-color: rgba(255, 255, 255, 0.15);
  }

  .category-header {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }

  .category-icon {
    font-size: 2rem;
    line-height: 1;
    flex-shrink: 0;
  }

  .category-title {
    font-family: 'jf-lanyangming', 'Noto Serif TC', serif;
    font-size: 1.5rem;
    font-weight: 700;
    color: #f1f5f9;
    margin-bottom: 0.25rem;
  }

  .category-desc {
    font-size: 0.95rem;
    color: #64748b;
    line-height: 1.5;
  }

  .item-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .item {
    padding: 0.6rem 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    line-height: 1.6;
  }

  .item:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }

  .item-link {
    color: #7dd3fc;
    text-decoration: none;
    font-weight: 600;
    font-size: 1rem;
    border-bottom: 1px solid transparent;
    transition: all 0.2s ease;
  }

  .item-link:hover {
    color: #bae6fd;
    border-bottom-color: #bae6fd;
  }

  .item-desc {
    color: #cbd5e1;
    font-size: 0.9rem;
  }

  .back-link {
    text-align: center;
    margin-top: 4rem;
    padding-top: 2rem;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
  }

  .btn-back {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.8rem 2rem;
    background: rgba(255, 255, 255, 0.06);
    color: #94a3b8;
    text-decoration: none;
    border-radius: 10px;
    font-weight: 600;
    font-size: 0.95rem;
    border: 1px solid rgba(255, 255, 255, 0.1);
    transition: all 0.2s ease;
  }

  .btn-back:hover {
    background: rgba(255, 255, 255, 0.1);
    color: #e2e8f0;
    border-color: rgba(255, 255, 255, 0.2);
  }

  @media (max-width: 768px) {
    .container { padding: 1rem; }
    .hero { padding: 2.5rem 0 2rem; }
    .category-card { padding: 1.5rem; }
    .category-header { gap: 0.75rem; }
    .category-icon { font-size: 1.5rem; }
    .category-title { font-size: 1.25rem; }
  }

  @media (max-width: 480px) {
    .container { padding: 0.75rem; }
    .category-card { padding: 1.25rem; }
    .item-link { font-size: 0.95rem; }
    .item-desc { display: block; margin-top: 0.25rem; font-size: 0.85rem; }
  }
</style>
