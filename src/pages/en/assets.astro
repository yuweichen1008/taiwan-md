---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Taiwan SVG — Open-Source Taiwan Outline" description="Accurate, open-source SVG outlines of Taiwan. AI always draws Taiwan wrong — here's the correct version." lang="en">
  <main class="assets-page">
    <section class="hero">
      <h1>Taiwan SVG — Open-Source Taiwan Outline</h1>
      <p class="subtitle">AI always draws Taiwan wrong. Here's the correct version.</p>
    </section>

    <section class="problem">
      <h2>🤖 Why Does AI Always Draw Taiwan Wrong?</h2>
      <p>Most AI image generation models lack structured geographic data for Taiwan in their training sets. The result: AI-generated images of Taiwan are often distorted, disproportionate, or confused with other islands.</p>
      <p>Taiwan.md provides <strong>accurate, open-source, freely usable</strong> SVG outlines of Taiwan — a definitive answer for every scenario that needs to know "what does Taiwan look like."</p>
    </section>

    <section class="svg-cards">
      <div class="card">
        <div class="card-preview">
          <img src="/assets/svg/taiwan-outline-simple.svg" alt="Taiwan Simple Outline" />
        </div>
        <div class="card-info">
          <h3>taiwan-outline-simple.svg</h3>
          <p class="card-desc">Simple — Best for icons, thumbnails, small sizes</p>
          <p class="card-meta">~80 control points · &lt;1 KB</p>
          <div class="card-actions">
            <a href="/assets/svg/taiwan-outline-simple.svg" download class="btn btn-primary">Download SVG</a>
            <button class="btn btn-outline" onclick="copySVG('taiwan-outline-simple.svg', this)">Copy SVG Code</button>
          </div>
        </div>
      </div>

      <div class="card">
        <div class="card-preview">
          <img src="/assets/svg/taiwan-outline-detailed.svg" alt="Taiwan Detailed Outline" />
        </div>
        <div class="card-info">
          <h3>taiwan-outline-detailed.svg</h3>
          <p class="card-desc">Detailed — Best for maps, print, large displays</p>
          <p class="card-meta">~160 control points · &lt;2 KB</p>
          <div class="card-actions">
            <a href="/assets/svg/taiwan-outline-detailed.svg" download class="btn btn-primary">Download SVG</a>
            <button class="btn btn-outline" onclick="copySVG('taiwan-outline-detailed.svg', this)">Copy SVG Code</button>
          </div>
        </div>
      </div>

      <div class="card">
        <div class="card-preview">
          <img src="/assets/svg/taiwan-full.svg" alt="Taiwan Full with Islands" />
        </div>
        <div class="card-info">
          <h3>taiwan-full.svg</h3>
          <p class="card-desc">Complete — Main island + outlying islands (Penghu, Kinmen, Matsu, Green Island, Orchid Island)</p>
          <p class="card-meta">Main island + 5 islands · ~1 KB</p>
          <div class="card-actions">
            <a href="/assets/svg/taiwan-full.svg" download class="btn btn-primary">Download SVG</a>
            <button class="btn btn-outline" onclick="copySVG('taiwan-full.svg', this)">Copy SVG Code</button>
          </div>
        </div>
      </div>
    </section>

    <section class="usage">
      <h2>📝 How to Use</h2>
      <div class="code-block">
        <pre><code>&lt;!-- Embed directly --&gt;
&lt;img src="https://taiwan.md/assets/svg/taiwan-outline-simple.svg" alt="Taiwan" width="200"&gt;

&lt;!-- As CSS background --&gt;
background-image: url('https://taiwan.md/assets/svg/taiwan-outline-simple.svg');

&lt;!-- In Markdown --&gt;
![Taiwan](https://taiwan.md/assets/svg/taiwan-outline-simple.svg)</code></pre>
      </div>
    </section>

    <section class="license">
      <h2>📄 License</h2>
      <p>All SVG files are released under <a href="https://creativecommons.org/licenses/by-sa/4.0/" target="_blank">CC BY-SA 4.0</a>. Free to use, modify, and use commercially — just give attribution.</p>
    </section>

    <section class="cta">
      <p>Found an issue or have suggestions?</p>
      <a href="https://github.com/frank890417/taiwan-md" target="_blank" class="btn btn-primary">Contribute on GitHub</a>
    </section>
  </main>

  <script is:inline>
    async function copySVG(filename, btn) {
      try {
        const res = await fetch('/assets/svg/' + filename);
        const text = await res.text();
        await navigator.clipboard.writeText(text);
        const orig = btn.textContent;
        btn.textContent = '✅ Copied';
        setTimeout(() => btn.textContent = orig, 2000);
      } catch(e) {
        btn.textContent = '❌ Failed';
        setTimeout(() => btn.textContent = 'Copy SVG Code', 2000);
      }
    }
  </script>

  <style>
    .assets-page {
      max-width: 900px;
      margin: 0 auto;
      padding: 2rem 1.5rem 4rem;
    }

    .hero {
      text-align: center;
      padding: 3rem 0 2rem;
    }
    .hero h1 {
      font-family: 'Noto Serif TC', serif;
      font-size: 2.2rem;
      color: #2d5016;
      margin-bottom: 0.5rem;
    }
    .subtitle {
      font-size: 1.2rem;
      color: #666;
    }

    .problem {
      margin: 2rem 0;
      line-height: 1.8;
    }
    .problem h2 {
      font-family: 'Noto Serif TC', serif;
      color: #2d5016;
      margin-bottom: 1rem;
    }

    .svg-cards {
      display: flex;
      flex-direction: column;
      gap: 2rem;
      margin: 2.5rem 0;
    }

    .card {
      display: flex;
      background: #fff;
      border-radius: 16px;
      box-shadow: 0 2px 12px rgba(0,0,0,0.08);
      overflow: hidden;
      transition: box-shadow 0.2s;
    }
    .card:hover {
      box-shadow: 0 4px 20px rgba(0,0,0,0.12);
    }

    .card-preview {
      flex: 0 0 200px;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 2rem;
      background: #f8faf5;
    }
    .card-preview img {
      max-height: 200px;
      max-width: 120px;
    }

    .card-info {
      padding: 1.5rem 2rem;
      flex: 1;
      display: flex;
      flex-direction: column;
      justify-content: center;
    }
    .card-info h3 {
      font-family: 'Courier New', monospace;
      font-size: 1rem;
      color: #333;
      margin-bottom: 0.5rem;
    }
    .card-desc {
      color: #555;
      margin-bottom: 0.25rem;
    }
    .card-meta {
      color: #999;
      font-size: 0.85rem;
      margin-bottom: 1rem;
    }

    .card-actions {
      display: flex;
      gap: 0.75rem;
      flex-wrap: wrap;
    }

    .btn {
      display: inline-block;
      padding: 0.5rem 1.2rem;
      border-radius: 8px;
      font-size: 0.9rem;
      text-decoration: none;
      cursor: pointer;
      border: none;
      font-family: inherit;
      transition: all 0.2s;
    }
    .btn-primary {
      background: #2d5016;
      color: #fff;
    }
    .btn-primary:hover {
      background: #3d6b1e;
    }
    .btn-outline {
      background: transparent;
      color: #2d5016;
      border: 1.5px solid #2d5016;
    }
    .btn-outline:hover {
      background: #f0f5eb;
    }

    .usage {
      margin: 3rem 0 2rem;
    }
    .usage h2 {
      font-family: 'Noto Serif TC', serif;
      color: #2d5016;
      margin-bottom: 1rem;
    }
    .code-block {
      background: #1e1e1e;
      border-radius: 12px;
      padding: 1.5rem;
      overflow-x: auto;
    }
    .code-block code {
      color: #d4d4d4;
      font-size: 0.85rem;
      line-height: 1.6;
      white-space: pre;
    }

    .license {
      margin: 2rem 0;
    }
    .license h2 {
      font-family: 'Noto Serif TC', serif;
      color: #2d5016;
      margin-bottom: 0.5rem;
    }
    .license a {
      color: #2d5016;
      text-decoration: underline;
    }

    .cta {
      text-align: center;
      margin: 3rem 0 1rem;
    }
    .cta p {
      margin-bottom: 1rem;
      color: #666;
    }

    @media (max-width: 640px) {
      .card {
        flex-direction: column;
      }
      .card-preview {
        flex: none;
        padding: 1.5rem;
      }
      .card-preview img {
        max-height: 150px;
      }
      .card-info {
        padding: 1rem 1.5rem 1.5rem;
      }
      .hero h1 {
        font-size: 1.6rem;
      }
    }
  </style>
</Layout>
