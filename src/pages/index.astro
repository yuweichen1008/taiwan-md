---
import Layout from '../layouts/Layout.astro';
import CategoryGrid from '../components/CategoryGrid.astro';
import { getCollection } from 'astro:content';

// Build graph data server-side
const allZhArticles = await getCollection('zh-TW');
const allEnArticles = await getCollection('en');

const categories = ['history', 'geography', 'culture', 'food', 'art', 'music', 'technology', 'nature', 'people', 'society', 'economy', 'lifestyle'];
const categoryNames: Record<string, string> = {
  history: '📜 歷史', geography: '🗺️ 地理', culture: '🎭 文化', food: '🍜 美食',
  art: '🎨 藝術', music: '🎵 音樂', technology: '💻 科技', nature: '🌿 自然',
  people: '👤 人物', society: '⚖️ 社會', economy: '📈 經濟', lifestyle: '🏮 生活'
};
const categoryColors: Record<string, string> = {
  history: '#dc2626', geography: '#2563eb', culture: '#7c3aed', food: '#ea580c',
  art: '#db2777', music: '#4f46e5', technology: '#0891b2', nature: '#16a34a',
  people: '#ca8a04', society: '#64748b', economy: '#0d9488', lifestyle: '#f97316'
};

const graphNodes: any[] = [{ id: 'taiwan', label: '🇹🇼 Taiwan.md', group: 'center', size: 28, color: '#2d5016' }];
const graphEdges: any[] = [];
const tagMap: Record<string, string[]> = {};

for (const cat of categories) {
  graphNodes.push({ id: cat, label: categoryNames[cat], group: cat, color: categoryColors[cat], size: 18, url: `/${cat}` });
  graphEdges.push({ source: 'taiwan', target: cat });

  const catArticles = allZhArticles.filter(a => a.id.split('/')[0] === cat && !a.id.split('/').pop()?.startsWith('_'));
  for (const article of catArticles) {
    const slug = article.id.split('/').slice(1).join('/').replace(/\.md$/, '');
    const nodeId = `${cat}/${slug}`;
    graphNodes.push({ id: nodeId, label: article.data.title, group: cat, color: categoryColors[cat], size: 7, url: `/${cat}/${encodeURIComponent(slug)}` });
    graphEdges.push({ source: cat, target: nodeId });
    if (article.data.tags) {
      for (const tag of article.data.tags) {
        if (!tagMap[tag]) tagMap[tag] = [];
        tagMap[tag].push(nodeId);
      }
    }
  }

  const enCatArticles = allEnArticles.filter(a => a.id.split('/')[0] === cat && !a.id.split('/').pop()?.startsWith('_'));
  for (const article of enCatArticles) {
    const slug = article.id.split('/').slice(1).join('/').replace(/\.md$/, '');
    const nodeId = `en/${cat}/${slug}`;
    graphNodes.push({ id: nodeId, label: `🌐 ${article.data.title}`, group: cat, color: categoryColors[cat], size: 5, url: `/en/${cat}/${slug}` });
    graphEdges.push({ source: cat, target: nodeId });
  }
}

// Cross-category tag edges
for (const [tag, ids] of Object.entries(tagMap)) {
  if (ids.length >= 2) {
    for (let i = 0; i < Math.min(ids.length - 1, 3); i++) {
      for (let j = i + 1; j < Math.min(ids.length, 4); j++) {
        const catA = ids[i].split('/')[0];
        const catB = ids[j].split('/')[0];
        if (catA !== catB) graphEdges.push({ source: ids[i], target: ids[j] });
      }
    }
  }
}

const graphData = JSON.stringify({ nodes: graphNodes, edges: graphEdges });
