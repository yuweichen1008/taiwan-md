---
import Layout from '../layouts/Layout.astro';
import CategoryGrid from '../components/CategoryGrid.astro';
import { getCollection } from 'astro:content';
// Fetch recent commits from GitHub API (works in shallow clone CI/CD environments)
let recentCommits: { hash: string; date: string; message: string }[] = [];
try {
  const res = await fetch('https://api.github.com/repos/frank890417/taiwan-md/commits?per_page=5');
  if (res.ok) {
    const data = await res.json();
    recentCommits = data.map((c: any) => ({
      hash: c.sha,
      date: c.commit.author.date,
      message: c.commit.message.split('\n')[0],
    }));
  }
} catch (e) {
  // silently fail
}

function commitIcon(msg: string) {
  if (msg.startsWith('feat')) return '✨';
  if (msg.startsWith('fix')) return '🐛';
  if (msg.startsWith('content')) return '📝';
  if (msg.startsWith('docs')) return '📖';
  return '📌';
}

function timeAgo(dateStr: string) {
  const now = new Date();
  const then = new Date(dateStr);
  const diff = Math.floor((now.getTime() - then.getTime()) / 1000);
  if (diff < 3600) return `${Math.floor(diff / 60)} 分鐘前`;
  if (diff < 86400) return `${Math.floor(diff / 3600)} 小時前`;
  if (diff < 604800) return `${Math.floor(diff / 86400)} 天前`;
  return then.toLocaleDateString('zh-TW', { month: 'short', day: 'numeric' });
}

let allZhArticles = [];
try {
  allZhArticles = await getCollection('zh-TW');
} catch (error) {
  allZhArticles = [];
}

const categoryNames: Record<string, string> = {
  history: '📜 歷史', geography: '🗺️ 地理', culture: '🎭 文化', food: '🍜 美食',
  art: '🎨 藝術', music: '🎵 音樂', technology: '💻 科技', nature: '🌿 自然',
  people: '👤 人物', society: '⚖️ 社會', economy: '📈 經濟', lifestyle: '🏮 生活'
};

// Prepare article list for random discovery
let allArticles = [];

if (allZhArticles.length > 0) {
  allArticles = allZhArticles
    .filter(article => !article.id.includes('/_') && !article.id.endsWith('/_Hub.md'))
    .map(article => {
      const slug = article.id.split('/').slice(1).join('/').replace(/\.md$/, '');
      const category = article.id.split('/')[0];
      return {
        title: article.data.title,
        url: `/${category}/${encodeURIComponent(slug)}`,
        category: categoryNames[category] || category
      };
    });
} else {
  // Fallback to hardcoded articles for now
  allArticles = [
    { title: '台灣民謠與歌謠', url: '/music/台灣民謠與歌謠', category: '🎵 音樂' },
    { title: '流行音樂與金曲獎', url: '/music/流行音樂與金曲獎', category: '🎵 音樂' },
    { title: '經濟奇蹟', url: '/economy/經濟奇蹟', category: '📈 經濟' },
    { title: '開源社群與g0v', url: '/technology/開源社群與g0v', category: '💻 科技' },
    { title: '半導體產業', url: '/technology/半導體產業', category: '💻 科技' }
  ];
}

const randomArticlesData = JSON.stringify(allArticles);
---

