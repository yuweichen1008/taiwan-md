  /* ===== 隨機發現台灣 ===== */
  .random-discovery {
    max-width: 600px;
    margin: 4rem auto;
    padding: 3rem 2rem;
    text-align: center;
    background: linear-gradient(135deg, #fffbeb 0%, #fef3c7 50%, #fed7aa 100%);
    border-radius: 24px;
    border: 1px solid rgba(245, 158, 11, 0.2);
    position: relative;
    overflow: hidden;
  }
  
  .random-discovery::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: url("data:image/svg+xml,%3Csvg width='30' height='30' viewBox='0 0 30 30' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='%23f59e0b' fill-opacity='0.03' fill-rule='evenodd'%3E%3Cpath d='M15 0L20 10L30 15L20 20L15 30L10 20L0 15L10 10Z'/%3E%3C/g%3E%3C/svg%3E");
    opacity: 0.6;
  }
  
  .random-discovery-content {
    position: relative;
    z-index: 2;
  }
  
  .random-btn {
    background: linear-gradient(135deg, #f59e0b, #d97706);
    color: white;
    border: none;
    border-radius: 20px;
    padding: 1.5rem 3rem;
    font-size: 1.3rem;
    font-weight: 700;
    cursor: pointer;
    transition: all 0.3s ease;
    position: relative;
    overflow: hidden;
    box-shadow: 0 8px 25px rgba(245, 158, 11, 0.3);
    margin-bottom: 1.5rem;
    min-width: 280px;
    font-family: "Noto Serif TC", "Source Han Serif TC", "PMingLiU", serif;
  }
  
  .random-btn::before {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.2), transparent);
    transition: left 0.5s ease;
  }
  
  .random-btn:hover::before {
    left: 100%;
  }
  
  .random-btn:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 30px rgba(245, 158, 11, 0.4);
    background: linear-gradient(135deg, #d97706, #b45309);
  }
  
  .random-btn:active {
    transform: scale(0.95) translateY(-4px);
  }
  
  .random-icon {
    font-size: 1.8rem;
    margin-right: 0.5rem;
    display: inline-block;
    animation: dice-roll 2s ease-in-out infinite;
  }
  
  @keyframes dice-roll {
    0%, 100% { transform: rotate(0deg) scale(1); }
    25% { transform: rotate(5deg) scale(1.05); }
    50% { transform: rotate(-5deg) scale(1.1); }
    75% { transform: rotate(3deg) scale(1.05); }
  }
  
  .random-text {
    display: block;
    font-size: 1.3rem;
    line-height: 1.2;
    margin-bottom: 0.3rem;
  }
  
  .random-subtitle {
    display: block;
    font-size: 0.9rem;
    opacity: 0.9;
    font-weight: 500;
    line-height: 1;
  }
  
  .random-description {
