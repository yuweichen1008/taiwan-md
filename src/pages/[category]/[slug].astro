---
import { readdir, readFile } from 'fs/promises';
import { resolve, join, basename } from 'path';
import matter from 'gray-matter';

export async function getStaticPaths() {
  const paths: any[] = [];
  
  // 類別對應到資料夾名稱
  const categoryMapping: Record<string, string> = {
    'history': 'History',
    'geography': 'Geography', 
    'culture': 'Culture',
    'food': 'Food',
    'art': 'Art',
    'music': 'Music',
    'technology': 'Technology',
    'nature': 'Nature',
    'people': 'People',
    'society': 'Society',
    'economy': 'Economy',
    'lifestyle': 'Lifestyle'
  };

  for (const [categorySlug, folderName] of Object.entries(categoryMapping)) {
    try {
      // 中文版本
      const zhFolderPath = resolve(process.cwd(), 'knowledge', folderName);
      try {
        const zhFiles = await readdir(zhFolderPath);
        const zhMarkdownFiles = zhFiles.filter(file => file.endsWith('.md') && !file.startsWith('_'));
        
        for (const file of zhMarkdownFiles) {
          const filePath = join(zhFolderPath, file);
          const fileContent = await readFile(filePath, 'utf-8');
          const { data: frontmatter, content } = matter(fileContent);
          
          // 檔案名稱作為 slug（去掉 .md）
          const slug = basename(file, '.md');
          
          paths.push({
            params: { 
              category: categorySlug, 
              slug: slug 
            },
            props: {
              title: frontmatter.title || slug,
              description: frontmatter.description || '',
              content: content,
              frontmatter: frontmatter,
              lang: 'zh-TW'
            }
          });
        }
      } catch (err) {
        console.log(`No Chinese folder found for ${folderName}:`, err.message);
      }

      // 英文版本
      const enFolderPath = resolve(process.cwd(), 'knowledge', 'en', folderName);
      try {
        const enFiles = await readdir(enFolderPath);
        const enMarkdownFiles = enFiles.filter(file => file.endsWith('.md') && !file.startsWith('_'));
        
        for (const file of enMarkdownFiles) {
          const filePath = join(enFolderPath, file);
          const fileContent = await readFile(filePath, 'utf-8');
          const { data: frontmatter, content } = matter(fileContent);
          
          // 檔案名稱作為 slug（去掉 .md）
          const slug = basename(file, '.md');
          
          paths.push({
            params: { 
              category: categorySlug, 
              slug: slug 
            },
            props: {
              title: frontmatter.title || slug,
              description: frontmatter.description || '',
              content: content,
              frontmatter: frontmatter,
              lang: 'en'
            }
          });
        }
      } catch (err) {
        console.log(`No English folder found for ${folderName}:`, err.message);
      }
      
    } catch (err) {
      console.log(`Error processing category ${categorySlug}:`, err.message);
    }
  }

  console.log(`Generated ${paths.length} paths for articles`);
  paths.forEach(path => {
    console.log(`Path: /${path.params.category}/${path.params.slug} (${path.props.title})`);
  });

  return paths;
}

import Layout from '../../layouts/Layout.astro';

const { title, description, content, frontmatter, lang } = Astro.props;
const { category, slug } = Astro.params;

const categoryInfo = {
  'history': { name: '歷史', icon: '📜' },
  'geography': { name: '地理', icon: '🗺️' },
  'culture': { name: '文化', icon: '🎭' },
  'food': { name: '美食', icon: '🍜' },
  'art': { name: '藝術', icon: '🎨' },
  'music': { name: '音樂', icon: '🎵' },
  'technology': { name: '科技', icon: '💻' },
  'nature': { name: '自然', icon: '🌿' },
  'people': { name: '人物', icon: '👥' },
  'society': { name: '社會', icon: '🏛️' },
  'economy': { name: '經濟', icon: '📊' },
  'lifestyle': { name: '生活', icon: '🏠' }
};

const currentCategory = categoryInfo[category as keyof typeof categoryInfo];

// 處理 Markdown 內容以支援基本 HTML 渲染
function processMarkdown(markdownContent: string) {
  return markdownContent
    // 處理標題
    .replace(/^### (.+)$/gm, '<h3>$1</h3>')
    .replace(/^## (.+)$/gm, '<h2>$1</h2>')
    .replace(/^# (.+)$/gm, '<h1>$1</h1>')
    // 處理粗體和斜體
    .replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')
    .replace(/\*(.+?)\*/g, '<em>$1</em>')
    // 處理連結
    .replace(/\[([^\]]+)\]\(([^)]+)\)/g, '<a href="$2" target="_blank" rel="noopener">$1</a>')
    // 處理引用區塊
    .replace(/^> (.+)$/gm, '<blockquote>$1</blockquote>')
    // 處理段落
    .replace(/^(?!<[h1-6]|<blockquote|<ul|<ol|<li)(.+)$/gm, '<p>$1</p>')
    // 處理清單
    .replace(/^- (.+)$/gm, '<li>$1</li>')
    .replace(/(<li>.*<\/li>)/s, '<ul>$1</ul>')
    // 清理多餘的空行
    .replace(/\n\s*\n/g, '\n');
}

const processedContent = processMarkdown(content);
---

<Layout 
  title={`${title} - Taiwan.md`}
  description={description}
>
  <main class="article-page">
    <div class="container">
      <!-- Breadcrumb -->
      <nav class="breadcrumb">
        <a href="/">首頁</a>
        <span class="separator">›</span>
        <a href={`/${category}`}>{currentCategory?.name || category}</a>
        <span class="separator">›</span>
        <span class="current">{title}</span>
      </nav>

      <!-- Article Header -->
      <header class="article-header">
        <div class="category-label">
          <span class="category-icon">{currentCategory?.icon || '📄'}</span>
          <span class="category-name">{currentCategory?.name || category}</span>
        </div>
        
        <h1 class="article-title">{title}</h1>
        
        <p class="article-description">{description}</p>

        <div class="article-meta">
          {frontmatter.readingTime && (
            <div class="meta-item">
              <span class="meta-icon">📖</span>
              <span>{frontmatter.readingTime} 分鐘閱讀</span>
            </div>
          )}
          
          {frontmatter.date && (
            <div class="meta-item">
              <span class="meta-icon">📅</span>
              <span>{new Date(frontmatter.date).toLocaleDateString('zh-TW')}</span>
            </div>
          )}

          {frontmatter.status && (
            <div class="meta-item">
              <span class="meta-icon">🎯</span>
              <span class="status">{frontmatter.status}</span>
            </div>
          )}
          
          {lang && (
            <div class="meta-item">
              <span class="meta-icon">🌐</span>
              <span>{lang === 'zh-TW' ? '繁體中文' : 'English'}</span>
            </div>
          )}
        </div>
      </header>

      <!-- Article Content -->
      <article class="article-content">
        <div class="content" set:html={processedContent}></div>
        
        {frontmatter.source && (
          <div class="sources">
            <h3>參考資料</h3>
            <ul>
              {frontmatter.source.map((url: string) => (
                <li><a href={url} target="_blank" rel="noopener">{url}</a></li>
              ))}
            </ul>
          </div>
        )}
      </article>

      <!-- Back Navigation -->
      <div class="back-navigation">
        <a href={`/${category}`} class="btn-secondary">
          ← 返回 {currentCategory?.name || category}
        </a>
        <a href="/" class="btn-secondary">
          返回首頁
        </a>
      </div>
    </div>
  </main>
</Layout>

<style>
