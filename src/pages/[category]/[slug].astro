---
import { readdir, readFile } from 'fs/promises';
import { resolve, join, basename } from 'path';
import matter from 'gray-matter';
import Layout from '../../layouts/Layout.astro';
import { marked } from 'marked';
import { categoryConfig, getCategoryConfig, type CategoryKey } from '../../utils/categoryConfig';

export async function getStaticPaths() {
  const paths: any[] = [];
  const categoryMapping: Record<string, string> = {
    history: 'History',
    geography: 'Geography',
    culture: 'Culture',
    food: 'Food',
    art: 'Art',
    music: 'Music',
    technology: 'Technology',
    nature: 'Nature',
    people: 'People',
    society: 'Society',
    economy: 'Economy',
    lifestyle: 'Lifestyle',
  };

  for (const [categorySlug, folderName] of Object.entries(categoryMapping)) {
    try {
      const zhFolderPath = resolve(process.cwd(), 'knowledge', folderName);
      const zhFiles = await readdir(zhFolderPath);
      const zhMarkdownFiles = zhFiles.filter((file) => file.endsWith('.md') && !file.startsWith('_'));

      for (const file of zhMarkdownFiles) {
        const filePath = join(zhFolderPath, file);
        const fileContent = await readFile(filePath, 'utf-8');
        const { data: frontmatter, content } = matter(fileContent);
        const slug = basename(file, '.md');

        paths.push({
          params: { category: categorySlug, slug },
          props: {
            title: frontmatter.title || slug,
            description: frontmatter.description || '',
            content,
            frontmatter,
            lang: 'zh-TW',
          },
        });
      }
    } catch {}
  }

  return paths;
}

const { title, description, content, frontmatter, lang } = Astro.props;
const { category, slug } = Astro.params;

const categoryInfo = getCategoryConfig(category);
if (!categoryInfo) {
  throw new Error(`Unknown category: ${category}`);
}

// 推薦文章 (簡化版，取同分類的其他文章)
const otherCategories = Object.keys(categoryConfig)
  .filter(cat => cat !== category)
  .slice(0, 3)
  .map(cat => ({
    key: cat,
    ...categoryConfig[cat as CategoryKey]
  }));

const categoryMapping: Record<string, string> = {
  history: 'History',
  geography: 'Geography',
  culture: 'Culture',
  food: 'Food',
  art: 'Art',
  music: 'Music',
  technology: 'Technology',
  nature: 'Nature',
  people: 'People',
  society: 'Society',
  economy: 'Economy',
  lifestyle: 'Lifestyle',
};

let relatedArticles: any[] = [];
try {
  const folderName = categoryMapping[category as string];
  if (folderName) {
    const categoryFolderPath = resolve(process.cwd(), 'knowledge', folderName);
    const files = await readdir(categoryFolderPath);
    const markdownFiles = files.filter((file) => file.endsWith('.md') && !file.startsWith('_'));

    for (const file of markdownFiles) {
      const articleSlug = basename(file, '.md');
      if (articleSlug !== slug) {
        const filePath = join(categoryFolderPath, file);
        const fileContent = await readFile(filePath, 'utf-8');
        const { data: frontmatter } = matter(fileContent);

        relatedArticles.push({
          title: frontmatter.title || articleSlug,
          slug: articleSlug,
          description: frontmatter.description || '',
          category,
        });
      }
    }

    relatedArticles = relatedArticles.slice(0, 3);
  }
} catch {}

function resolveWikilinks(markdownContent: string) {
  if (!markdownContent) return markdownContent;
  return markdownContent.replace(/\[\[([^\]|]+?)(?:\|([^\]]+?))?\]\]/g, (_, target, display) => {
    const label = display || target;
    return `**${label}**`;
  });
}

const resolvedContent = resolveWikilinks(content);
const processedContent = marked.parse(resolvedContent);
---

<Layout 
  title={title}
  description={description}
  type="article"
  datePublished={frontmatter.date || new Date().toISOString()}
  dateModified={frontmatter.modified || frontmatter.date || new Date().toISOString()}
  content={content}
>
  <!-- Reading Progress Bar -->
  <div class="reading-progress" id="reading-progress"></div>

  <main class="article-page">
    <!-- Article Header Banner -->
    <section class="article-header-banner" style={`background: ${categoryInfo.gradient};`}>
      <div class="header-content">
        <nav class="breadcrumb-header">
          <a href="/" class="breadcrumb-link">首頁</a>
          <span class="separator">›</span>
          <a href={`/${category}`} class="breadcrumb-link">{categoryInfo.name}</a>
          <span class="separator">›</span>
          <span class="current">{title}</span>
        </nav>
        
        <h1 class="article-title-header">{title}</h1>
        <p class="article-description-header">{description}</p>
      </div>
    </section>

    <!-- Article Content -->
    <div class="container">
      <article class="article-content">
        <!-- Meta Information -->
        <div class="article-meta">
          <div class="meta-group">
            <div class="category-badge" style={`background: ${categoryInfo.colorLight}; color: ${categoryInfo.color}; border-color: ${categoryInfo.color};`}>
              <span class="category-icon">{categoryInfo.icon}</span>
              <span class="category-name">{categoryInfo.name}</span>
            </div>
            
            {frontmatter.readingTime && (
              <div class="meta-item">
                <span class="meta-icon">📖</span>
                <span>{frontmatter.readingTime} 分鐘閱讀</span>
              </div>
            )}
            
            {frontmatter.date && (
              <div class="meta-item">
                <span class="meta-icon">📅</span>
                <span>{new Date(frontmatter.date).toLocaleDateString('zh-TW')}</span>
              </div>
            )}

            {frontmatter.status && (
              <div class="meta-item">
                <span class="status-tag" style={`background: ${categoryInfo.colorLight}; color: ${categoryInfo.color};`}>{frontmatter.status}</span>
              </div>
            )}
          </div>
          
          {lang && (
            <div class="lang-badge">
              <span class="meta-icon">🌐</span>
              <span>{lang === 'zh-TW' ? '繁體中文' : 'English'}</span>
            </div>
          )}
        </div>

        <!-- Main Content -->
        <div class="content" set:html={processedContent}></div>
        
        {frontmatter.source && (
          <div class="sources">
            <h3>參考資料</h3>
            <ul>
              {frontmatter.source.map((url: string) => (
                <li><a href={url} target="_blank" rel="noopener">{url}</a></li>
              ))}
            </ul>
          </div>
        )}

        <!-- Tags and Share -->
        <div class="article-footer">
          <div class="tags-section">
            {frontmatter.tags && frontmatter.tags.length > 0 && (
              <div class="tags">
                {frontmatter.tags.map((tag: string) => (
                  <span class="tag" style={`background: ${categoryInfo.colorLight}; color: ${categoryInfo.color};`}>{tag}</span>
                ))}
              </div>
            )}
          </div>
          
          <div class="share-section">
            <span class="share-label">分享這篇文章：</span>
            <div class="share-buttons">
              <a href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(title)}&url=${encodeURIComponent(`https://taiwan.md/${category}/${slug}`)}`} 
                 target="_blank" 
                 class="share-btn twitter">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M23 3a10.9 10.9 0 01-3.14 1.53 4.48 4.48 0 00-7.86 3v1A10.66 10.66 0 013 4s-4 9 5 13a11.64 11.64 0 01-7 2c9 5 20 0 20-11.5a4.5 4.5 0 00-.08-.83A7.72 7.72 0 0023 3z"/>
                </svg>
                Twitter
              </a>
              <a href={`https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(`https://taiwan.md/${category}/${slug}`)}`} 
                 target="_blank" 
                 class="share-btn facebook">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/>
                </svg>
                Facebook
              </a>
            </div>
          </div>
        </div>

        <!-- 延伸閱讀：同分類其他文章 -->
        {relatedArticles.length > 0 && (
          <div class="related-articles">
            <h3 class="related-title">延伸閱讀</h3>
            <div class="related-grid">
              {relatedArticles.map(article => (
                <a href={`/${article.category}/${article.slug}`} class="related-card" style={`border-color: ${categoryInfo.color};`}>
                  <div class="related-card-content">
                    <h4 class="related-card-title" style={`color: ${categoryInfo.color};`}>{article.title}</h4>
                    {article.description && (
                      <p class="related-card-desc">{article.description}</p>
                    )}
                  </div>
                  <div class="related-card-arrow" style={`color: ${categoryInfo.color};`}>→</div>
                </a>
              ))}
            </div>
          </div>
        )}

        <!-- More Articles -->
        <div class="more-articles">
          <h3 class="more-title">探索更多台灣面向</h3>
          <div class="more-grid">
            {otherCategories.map(cat => (
              <a href={`/${cat.key}`} class="more-card" style={`border-color: ${cat.color};`}>
                <div class="more-card-icon" style={`color: ${cat.color};`}>{cat.icon}</div>
                <div class="more-card-content">
                  <div class="more-card-name" style={`color: ${cat.color};`}>{cat.name}</div>
                  <div class="more-card-desc">{cat.description}</div>
                </div>
              </a>
            ))}
          </div>
        </div>

        <!-- Article Footer Actions -->
        <div class="article-footer-actions">
          <hr class="section-divider" />
          
          <!-- 推薦下一篇 (Retention Loop) -->
          {relatedArticles.length > 0 && (
            <div class="recommended-reading">
              <h3 class="footer-section-title">你可能也會喜歡</h3>
              <div class="recommended-grid">
                {relatedArticles.slice(0, 2).map(article => (
                  <a href={`/${article.category}/${article.slug}`} class="recommended-card">
                    <h4 class="recommended-title">{article.title}</h4>
                    <div class="recommended-category" style={`background: ${categoryInfo.colorLight}; color: ${categoryInfo.color};`}>
                      <span class="category-icon">{categoryInfo.icon}</span>
                      <span>{categoryInfo.name}</span>
                    </div>
                  </a>
                ))}
              </div>
            </div>
          )}

          <hr class="section-divider" />

          <!-- Edit on GitHub (Contribution Funnel) -->
          <div class="contribute-section">
            <h3 class="footer-section-title">幫助改善內容</h3>
            <p class="contribute-note">
              本文內容由 AI 初步生成，希望集結大家的力量，讓內容越來越完整、正確！<br>
              如果您發現任何問題，或手邊有更多推薦的資料來源，歡迎直接編輯或<a href="mailto:cheyu.wu@monoame.com">聯繫我們</a>。<br>
              感謝每一位用心 feedback 的朋友！
            </p>
            <div class="contribute-actions">
              <a 
                href={`https://github.com/frank890417/taiwan-md/edit/main/knowledge/${categoryMapping[category as string]}/${slug}.md`}
                target="_blank" 
                class="contribute-btn edit-btn"
                rel="noopener"
              >
                <span class="contribute-icon">📝</span>
                <span>在 GitHub 上編輯此頁</span>
              </a>
              <a 
                href={`https://github.com/frank890417/taiwan-md/issues/new?title=${encodeURIComponent(`Feedback: ${title}`)}`}
                target="_blank" 
                class="contribute-btn issue-btn"
                rel="noopener"
              >
                <span class="contribute-icon">💬</span>
                <span>回報問題</span>
              </a>
            </div>
          </div>

          <hr class="section-divider" />

          <!-- 社交分享 (Sharing Loop) -->
          <div class="social-sharing">
            <h3 class="footer-section-title">分享給更多人</h3>
            <div class="sharing-buttons">
              <a 
                href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(title)}&url=${encodeURIComponent(`https://taiwan.md/${category}/${slug}`)}`}
                target="_blank" 
                class="share-button twitter-btn"
                rel="noopener"
              >
                <span class="share-icon">𝕏</span>
                <span>分享到 X</span>
              </a>
              <a 
                href={`https://social-plugins.line.me/lineit/share?url=${encodeURIComponent(`https://taiwan.md/${category}/${slug}`)}`}
                target="_blank" 
                class="share-button line-btn"
                rel="noopener"
              >
                <span class="share-icon">💚</span>
                <span>分享到 LINE</span>
              </a>
              <button 
                class="share-button copy-btn"
                onclick="copyToClipboard()"
                type="button"
              >
                <span class="share-icon">📋</span>
                <span>複製連結</span>
              </button>
            </div>
          </div>
        </div>
      </article>

      <!-- Navigation -->
      <div class="article-navigation">
        <a href={`/${category}`} class="nav-btn back-btn" style={`background: ${categoryInfo.color};`}>
          ← 返回 {categoryInfo.name}
        </a>
        <a href="/" class="nav-btn home-btn">
          返回首頁
        </a>
      </div>
    </div>
  </main>
</Layout>

<script>
  // Reading progress bar
  function updateReadingProgress() {
    const article = document.querySelector('.content');
    if (!article) return;
    
    const scrolled = window.scrollY;
    const articleTop = article.offsetTop;
    const articleHeight = article.offsetHeight;
    const windowHeight = window.innerHeight;
    
    const progress = Math.min(
      Math.max((scrolled - articleTop + windowHeight * 0.3) / articleHeight * 100, 0),
      100
    );
    
    const progressBar = document.getElementById('reading-progress');
    if (progressBar) {
      progressBar.style.width = progress + '%';
    }
  }
  
  // Copy to clipboard function
  function copyToClipboard() {
    const url = window.location.href;
    navigator.clipboard.writeText(url).then(() => {
      const btn = document.querySelector('.copy-btn');
      const originalText = btn.innerHTML;
      btn.innerHTML = '<span class="share-icon">✅</span><span>已複製</span>';
      btn.style.background = '#10b981';
      btn.style.color = 'white';
      
      setTimeout(() => {
        btn.innerHTML = originalText;
        btn.style.background = '';
        btn.style.color = '';
      }, 2000);
    }).catch(() => {
      // Fallback for older browsers
      const textArea = document.createElement('textarea');
      textArea.value = url;
      document.body.appendChild(textArea);
      textArea.select();
      document.execCommand('copy');
      document.body.removeChild(textArea);
      
      const btn = document.querySelector('.copy-btn');
      const originalText = btn.innerHTML;
      btn.innerHTML = '<span class="share-icon">✅</span><span>已複製</span>';
      setTimeout(() => {
        btn.innerHTML = originalText;
      }, 2000);
    });
  }
  
  window.addEventListener('scroll', updateReadingProgress);
  window.addEventListener('resize', updateReadingProgress);
  updateReadingProgress();
</script>

<style define:vars={{ categoryColor: categoryInfo.color, categoryColorLight: categoryInfo.colorLight }}>
  /* Reading Progress Bar */
  .reading-progress {
    position: fixed;
    top: 0;
    left: 0;
    width: 0%;
    height: 4px;
    background: var(--categoryColor);
    z-index: 1000;
    transition: width 0.1s ease;
  }

  .article-page {
    min-height: 100vh;
  }

  /* Header Banner */
  .article-header-banner {
    width: 100%;
    padding: clamp(2.75rem, 7vw, 4rem) var(--space-page-x);
    color: white;
    position: relative;
    overflow: hidden;
  }

  .article-header-banner::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      linear-gradient(180deg, rgba(15, 23, 42, 0.24) 0%, rgba(15, 23, 42, 0.12) 45%, rgba(15, 23, 42, 0.18) 100%);
    pointer-events: none;
  }

  .header-content {
    max-width: 800px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }

  .breadcrumb-header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 2rem;
    font-size: 0.96rem;
    flex-wrap: wrap;
    width: fit-content;
    max-width: 100%;
    padding: 0.65rem 0.9rem;
    border-radius: var(--radius-chip);
    background: rgba(15, 23, 42, 0.2);
    backdrop-filter: blur(8px);
    box-shadow: 0 8px 20px rgba(15, 23, 42, 0.12);
  }

  .breadcrumb-header a {
    color: #ffffff;
    text-decoration: none;
    font-weight: 600;
    border-bottom: none;
    padding-bottom: 0;
    text-shadow: none;
  }

  .breadcrumb-header a:hover {
    color: #ffffff;
    text-decoration: none;
    border-bottom: 1px solid rgba(255, 255, 255, 0.92);
  }

  .separator {
    color: rgba(255, 255, 255, 0.82);
  }

  .current {
    color: #ffffff;
    font-weight: 700;
    text-shadow: none;
  }

  .article-title-header {
    font-size: 3rem;
    font-weight: 800;
    line-height: 1.2;
    margin-bottom: 1rem;
    text-shadow: 0 3px 12px rgba(15, 23, 42, 0.34);
  }

  .article-description-header {
    font-size: 1.3rem;
    line-height: 1.5;
    color: rgba(255, 255, 255, 0.96);
    max-width: 42rem;
    text-shadow: 0 2px 8px rgba(15, 23, 42, 0.28);
  }

  /* Container */
  .container {
    max-width: var(--container-reading);
    margin: 0 auto;
    padding: 2rem var(--space-page-x);
  }

  /* Article Content */
  .article-content {
    margin-bottom: var(--space-7);
  }

  .article-meta {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    flex-wrap: wrap;
    gap: 1.25rem;
    margin-bottom: var(--space-8);
    padding-bottom: var(--space-6);
    border-bottom: 1px solid #e2e8f0;
  }

  .meta-group {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .category-badge {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.7rem 1.05rem;
    border: 1px solid;
    border-radius: var(--radius-chip);
    font-weight: 600;
    font-size: 0.95rem;
    box-shadow: 0 8px 22px rgba(15, 23, 42, 0.04);
  }

  .category-icon {
    font-size: 1.1rem;
  }

  .meta-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.65rem 0.95rem;
    font-size: 0.95rem;
    color: #64748b;
    background: rgba(255, 255, 255, 0.72);
    border: 1px solid rgba(148, 163, 184, 0.18);
    border-radius: var(--radius-chip);
    box-shadow: 0 8px 22px rgba(15, 23, 42, 0.04);
  }

  .meta-icon {
    font-size: 1rem;
  }

  .status-tag {
    padding: 0.45rem 0.8rem;
    border-radius: var(--radius-chip);
    font-weight: 500;
    font-size: 0.8rem;
    border: 1px solid rgba(148, 163, 184, 0.18);
  }

  .lang-badge {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.65rem 0.95rem;
    background: rgba(255, 255, 255, 0.72);
    border-radius: var(--radius-chip);
    font-size: 0.95rem;
    color: #64748b;
    border: 1px solid rgba(148, 163, 184, 0.18);
    box-shadow: 0 8px 22px rgba(15, 23, 42, 0.04);
  }

  /* Content Styling — 報導者風格排版 */
  .content {
    font-size: 1.125rem;
    line-height: 2;
    color: #333;
    max-width: 720px;
    margin: 0 auto;
    letter-spacing: 0.02em;
    background: rgba(255, 255, 255, 0.82);
    border: 1px solid rgba(226, 232, 240, 0.9);
    border-radius: 22px;
    padding: 2.25rem;
    box-shadow: var(--shadow-soft);
    backdrop-filter: blur(10px);
  }

  /* 標題層級系統 — 清晰的視覺層次 */
  .content h1, .content h2, .content h3, .content h4, .content h5, .content h6 {
    font-family: var(--font-editorial);
    color: #1a1a1a;
    line-height: 1.4;
    letter-spacing: var(--title-letter-spacing);
  }

  .content > h1:first-child {
    display: none;
  }

  .content h1 {
    font-size: 2rem;
    font-weight: 700;
    margin: 4rem 0 1.5rem 0;
  }

  .content h2 {
    font-size: var(--title-subsection-size);
    font-weight: 800;
    margin: 4rem 0 1.5rem 0;
    padding-bottom: 0.75rem;
    border-bottom: 2px solid var(--categoryColor);
  }

  .content h3 {
    font-size: var(--title-minor-size);
    font-weight: 700;
    margin: 3rem 0 1.2rem 0;
    color: #2d2d2d;
    padding-left: 0.75rem;
    border-left: 4px solid var(--categoryColor);
  }

  .content h4 {
    font-size: 1.125rem;
    font-weight: 700;
    margin: 2.5rem 0 1rem 0;
    color: #444;
  }

  /* 段落 — 大呼吸感 */
  .content p {
    margin-bottom: 1.75rem;
    line-height: 2.1;
    text-align: justify;
    word-break: break-word;
  }

  /* HR — 報導者風格大間距分隔 */
  .content hr {
    border: none;
    border-top: 1px solid #e0e0e0;
    margin: 3.5rem auto;
    max-width: 120px;
  }

  /* Blockquote — 沈靜引言 */
  .content blockquote {
    border-left: 4px solid var(--categoryColor);
    background: linear-gradient(to right, var(--categoryColorLight), transparent);
    padding: 1.5rem 2rem;
    margin: 2.5rem 0;
    font-style: italic;
    color: #555;
    border-radius: 0 8px 8px 0;
    font-size: 1.05rem;
    line-height: 2;
  }

  .content blockquote p {
    margin-bottom: 0.75rem;
  }

  .content blockquote p:last-child {
    margin-bottom: 0;
  }

  /* 列表 — 寬鬆行距 */
  .content ul,
  .content ol {
    margin: 2rem 0;
    padding: 0;
  }

  .content ul {
    list-style: none;
  }

  .content ol {
    list-style: none;
    counter-reset: article-list;
  }

  .content li {
    position: relative;
    margin-bottom: 1rem;
    padding-left: 1.7rem;
    line-height: 1.9;
  }

  .content ul > li::before,
  .content ol > li::before {
    position: absolute;
    left: 0.3rem;
    top: 0.08rem;
    color: var(--categoryColor);
    font-weight: 700;
    line-height: 1.9;
  }

  .content ul > li::before {
    content: "•";
    font-size: 1.08em;
  }

  .content ol > li {
    counter-increment: article-list;
  }

  .content ol > li::before {
    content: counter(article-list) ".";
    font-size: 0.95em;
  }

  .content li > p {
