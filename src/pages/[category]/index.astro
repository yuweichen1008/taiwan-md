    margin-bottom: 2rem;
    opacity: 0.7;
  }

  .coming-soon-content h2 {
    font-size: var(--title-section-size);
    color: #1f2937;
    margin-bottom: 1rem;
    font-weight: 800;
    line-height: var(--title-line-height);
    letter-spacing: var(--title-letter-spacing);
    font-family: var(--font-editorial);
  }

