    font-weight: 600;
    font-size: 1.1rem;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .hero-banner {
      padding: var(--space-7) 1rem;
    }

    .hero-title {
      font-size: 2.5rem;
    }

