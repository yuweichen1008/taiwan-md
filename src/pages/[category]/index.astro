      font-size: 1.2rem;
    }

    .container {
      padding: 1rem;
    }

    .hub-content {
      padding: 1.5rem 1.25rem;
      border-radius: 20px;
    }

    .articles-grid {
      grid-template-columns: 1fr;
      gap: var(--space-4);
    }

    .featured-card {
      grid-column: 1;
    }

    .action-buttons {
      flex-direction: column;
      align-items: center;
    }

    .categories-grid {
      grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
    }
  }
</style>
